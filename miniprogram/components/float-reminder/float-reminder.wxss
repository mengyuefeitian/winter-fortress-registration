/* components/float-reminder/float-reminder.wxss */
.float-tip {
  position: fixed;
  top: 18%;
  left: 50%;
  transform: translateX(-50%);
  max-width: 78%;
  padding: 22rpx 34rpx;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 14rpx;
  z-index: 99999;
  box-sizing: border-box;
  opacity: 0;
  pointer-events: none; /* 不阻塞用户操作 */
}

.float-tip.show {
  animation: floatFade 3000ms ease forwards;
}

.float-tip-text {
  color: #ffffff;
  font-size: 26rpx;
  line-height: 1.5;
  text-align: center;
  display: block;
}

@keyframes floatFade {
  0% { opacity: 0; }
  12% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; }
}
