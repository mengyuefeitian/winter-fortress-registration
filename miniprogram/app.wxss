/* ==========================================================================
   App.wxss - Winter Fortress Design System (Deep Winter Glassmorphism)
   ========================================================================== */

/* --- 冬季堡垒配色体系 --- */
page {
  --wf-bg-start: #0F172A;
  --wf-bg-end: #1E293B;
  --wf-primary: #38BDF8;
  --wf-accent: #0EA5E9;
  --wf-text-main: #F8FAFC;
  --wf-text-sub: #94A3B8;
  --wf-glass: rgba(255, 255, 255, 0.08);
  --wf-border: rgba(255, 255, 255, 0.15);
  --wf-danger: #EF4444;
  --wf-success: #10B981;

  background: var(--wf-bg-start);
  color: var(--wf-text-main);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  min-height: 100vh;
}

/* --- 通用布局 --- */
.container { padding: 16px; box-sizing: border-box; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }

/* --- 玻璃拟态卡片 --- */
.wf-card {
  background: var(--wf-glass);
  border: 1px solid var(--wf-border);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
}

/* --- 冰川按钮 --- */
.wf-btn {
  background: linear-gradient(90deg, var(--wf-primary), var(--wf-accent));
  color: #fff;
  font-weight: 600;
  border-radius: 12px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  width: 100%;
  box-shadow: 0 4px 12px rgba(56, 189, 248, 0.3);
  font-size: 16px;
}

.wf-btn:active { opacity: 0.8; }

/* --- 输入框样式 --- */
.wf-input {
  background: rgba(0, 0, 0, 0.25);
  border: 1px solid var(--wf-border);
  color: var(--wf-text-main);
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 15px;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16px;
}

/* --- 标题与文字 --- */
.wf-title { font-size: 24px; font-weight: 700; letter-spacing: 1px; text-shadow: 0 2px 4px rgba(0,0,0,0.3); }
.wf-subtitle { font-size: 14px; color: var(--wf-text-sub); }

/* --- 状态标签 --- */
.wf-tag {
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  background: rgba(56, 189, 248, 0.15);
  color: var(--wf-primary);
  border: 1px solid rgba(56, 189, 248, 0.3);
}

/* --- 底部导航栏适配 --- */
.tab-bar-spacer { height: 80px; }


/* ==========================================================================
   Admin Compatibility Layer (Minimal Design System)
   Used by admin / auditor / superAdmin pages which were NOT redesigned.
   ========================================================================== */

/* .page: base layout for all pages (user-facing pages show dark gradient through transparent bg) */
/* .admin-page: adds white background for admin/auditor/superAdmin pages */
.page {
  min-height: 100vh;
  font-size: 14px;
  line-height: 1.6;
}
.admin-page {
  color: #F8FAFC;
  padding: 0 16px 24px;
}

