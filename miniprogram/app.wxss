/* app.wxss - 全局样式 */

/* 配色方案 */
/* 主色: #4A90D9 */
/* 辅助色: #6BB3F0 */
/* 背景: #F5F7FA */
/* 强调色: #FF6B6B */
/* 成功色: #52C41A */
/* 文字: #333333, #666666, #999999 */

/* 页面基础样式 */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 14px;
  color: #333333;
  line-height: 1.5;
}

/* 容器 */
.container {
  padding: 20px;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12px;
}

.card-content {
  font-size: 14px;
  color: #666666;
}

/* 按钮样式 */
.btn-primary {
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
  text-align: center;
}

.btn-primary:active {
  background-color: #3A80C9;
}

.btn-secondary {
  background-color: #6BB3F0;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
  text-align: center;
}

.btn-secondary:active {
  background-color: #5BA3E0;
}

.btn-outline {
  background-color: transparent;
  color: #4A90D9;
  border: 1px solid #4A90D9;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
  text-align: center;
}

.btn-outline:active {
  background-color: #F0F7FF;
}

.btn-danger {
  background-color: #FF6B6B;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
  text-align: center;
}

.btn-danger:active {
  background-color: #EF5B5B;
}

.btn-disabled {
  background-color: #CCCCCC;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
  text-align: center;
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 40px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
  color: #333333;
}

.input:focus {
  border-color: #4A90D9;
}

/* 选择器样式 */
.selector {
  width: 100%;
  height: 40px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
  color: #333333;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.selector-arrow {
  width: 16px;
  height: 16px;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
  margin-right: 8px;
}

.tag-primary {
  background-color: #E8F4FF;
  color: #4A90D9;
}

.tag-success {
  background-color: #E8FFE8;
  color: #52C41A;
}

.tag-warning {
  background-color: #FFF7E8;
  color: #FF9800;
}

.tag-danger {
  background-color: #FFE8E8;
  color: #FF6B6B;
}

/* 分割线 */
.divider {
  height: 1px;
  background-color: #E8E8E8;
  margin: 16px 0;
}

/* 状态指示 */
.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  margin-right: 8px;
}

.status-active {
  background-color: #52C41A;
}

.status-inactive {
  background-color: #CCCCCC;
}

.status-full {
  background-color: #FF6B6B;
}

/* 时间段卡片 */
.time-slot-card {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.time-slot-card.full {
  background-color: #F0F0F0;
  opacity: 0.6;
}

.time-slot-time {
  font-size: 18px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8px;
}

.time-slot-remark {
  font-size: 12px;
  color: #999999;
  margin-bottom: 8px;
}

.time-slot-count {
  font-size: 14px;
  color: #666666;
}

.time-slot-count.full {
  color: #FF6B6B;
}

/* 用户信息展示 */
.user-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: #E8E8E8;
}

.user-name {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.user-role {
  font-size: 12px;
  color: #999999;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #E8E8E8;
}

.list-item:last-child {
  border-bottom: none;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px;
}

.loading-text {
  color: #999999;
  font-size: 14px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 60px 20px;
}

.empty-icon {
  width: 80px;
  height: 80px;
  margin-bottom: 16px;
}

.empty-text {
  color: #999999;
  font-size: 14px;
  margin-bottom: 16px;
}

/* 网格布局 */
.grid-2 {
  display: flex;
  flex-wrap: wrap;
}

.grid-2-item {
  width: 50%;
  padding: 8px;
  box-sizing: border-box;
}

.grid-3 {
  display: flex;
  flex-wrap: wrap;
}

.grid-3-item {
  width: 33.33%;
  padding: 8px;
  box-sizing: border-box;
}

/* Flex布局 */
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-around {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* 文字样式 */
.text-primary {
  color: #4A90D9;
}

.text-secondary {
  color: #6BB3F0;
}

.text-success {
  color: #52C41A;
}

.text-warning {
  color: #FF9800;
}

.text-danger {
  color: #FF6B6B;
}

.text-muted {
  color: #999999;
}

.text-small {
  font-size: 12px;
}

.text-large {
  font-size: 16px;
}

.text-bold {
  font-weight: 500;
}

.text-center {
  text-align: center;
}

/* 间距 */
.mt-8 { margin-top: 8px; }
.mt-16 { margin-top: 16px; }
.mt-24 { margin-top: 24px; }
.mb-8 { margin-bottom: 8px; }
.mb-16 { margin-bottom: 16px; }
.mb-24 { margin-bottom: 24px; }
.ml-8 { margin-left: 8px; }
.ml-16 { margin-left: 16px; }
.mr-8 { margin-right: 8px; }
.mr-16 { margin-right: 16px; }
.p-8 { padding: 8px; }
.p-16 { padding: 16px; }
.p-24 { padding: 24px; }