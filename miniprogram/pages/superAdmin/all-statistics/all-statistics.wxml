<!--pages/superAdmin/all-statistics/all-statistics.wxml-->
<view class="page">
  <!-- 报名类型选择 -->
  <view class="card">
    <view class="form-row">
      <view class="form-col">
        <text class="form-label">报名类型</text>
        <picker bindchange="onRegTypeChange" value="{{regTypeIndex}}" range="{{registrationTypes}}">
          <view class="picker-compact">
            <text>{{selectedRegType}}</text>
            <image class="picker-compact-arrow" src="/images/icon-arrow-down.png"></image>
          </view>
        </picker>
      </view>
      <view class="form-col">
        <text class="form-label">分区</text>
        <zone-selector value="{{selectedZone}}" zones="{{zones}}" loaded="{{true}}" bind:change="onZoneChange" />
      </view>
    </view>
    <view class="form-row" wx:if="{{selectedRegType === '堡垒报名'}}">
      <view class="form-col">
        <text class="form-label">联盟</text>
        <picker wx:if="{{selectedZone}}" bindchange="onAllianceChange" value="{{allianceIndex}}" range="{{alliances}}" range-key="allianceName">
          <view class="picker-compact">
            <text>{{selectedAlliance ? selectedAlliance.allianceName : '请选择'}}</text>
            <image class="picker-compact-arrow" src="/images/icon-arrow-down.png"></image>
          </view>
        </picker>
        <view wx:else class="picker-compact disabled">
          <text class="picker-placeholder">请先选分区</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 堡垒报名统计 -->
  <view wx:if="{{selectedRegType === '堡垒报名' && selectedAlliance}}" class="card">
    <view class="stats-header">
      <view class="stats-title">{{selectedAlliance.allianceName}} 堡垒报名统计</view>
    </view>
    <view class="stats-actions">
      <button class="btn btn-danger btn-sm" bindtap="clearRegistrations">清空数据</button>
      <button class="btn btn-primary btn-sm" bindtap="saveScreenshot">保存截图</button>
    </view>

    <!-- 汇总数据 -->
    <view class="stats-summary">
      <view class="summary-item">
        <view class="summary-value">{{totalRegistrations}}</view>
        <view class="summary-label">总报名人数</view>
      </view>
      <view class="summary-item">
        <view class="summary-value">{{fullSlots}}</view>
        <view class="summary-label">已满时间段</view>
      </view>
      <view class="summary-item">
        <view class="summary-value">{{remainingSlots}}</view>
        <view class="summary-label">剩余名额</view>
      </view>
    </view>

    <!-- 时间段表格 -->
    <view wx:if="{{timeSlotStats.length > 0}}" class="table-container">
      <view class="table-row table-header-row">
        <text class="table-cell">时间段</text>
        <text class="table-cell">堡垒</text>
        <text class="table-cell">标签</text>
        <text class="table-cell">日期</text>
        <text class="table-cell">人数</text>
      </view>
      <view wx:for="{{timeSlotStats}}" wx:key="*this" class="table-row">
        <text class="table-cell">{{item.timeSlot.displayName}}</text>
        <text class="table-cell">{{item.timeSlot.fortress || '-'}}</text>
        <text class="table-cell">{{item.timeSlot.tag || '-'}}</text>
        <text class="table-cell">{{item.timeSlot.date || '-'}}</text>
        <text class="table-cell {{item.isFull ? 'full' : ''}}">{{item.count}}/{{item.timeSlot.maxCount}}</text>
      </view>
    </view>

    <!-- 时间段详情 -->
    <view class="time-slot-list">
      <view wx:for="{{timeSlotStats}}" wx:key="*this" class="time-slot-card">
        <view class="slot-header">
          <view class="slot-time">
            {{item.timeSlot.displayName}}
            <text wx:if="{{item.timeSlot.fortress}}" class="slot-tag fortress-tag">{{item.timeSlot.fortress}}</text>
            <text wx:if="{{item.timeSlot.tag}}" class="slot-tag">{{item.timeSlot.tag}}</text>
          </view>
          <view class="slot-status {{item.isFull ? 'full' : ''}}">
            {{item.count}}/{{item.timeSlot.maxCount}}人
          </view>
        </view>
        <view wx:if="{{item.timeSlot.date}}" class="slot-date">日期: {{item.timeSlot.date}}</view>

        <!-- 报名人员列表 -->
        <view wx:if="{{item.registrations.length > 0}}" class="registration-list">
          <view wx:for="{{item.registrations}}" wx:for-item="reg" wx:for-index="regIdx" wx:key="_id" class="registration-item">
            <view class="reg-order">{{regIdx + 1}}</view>
            <view class="reg-name">{{reg.nickName}}</view>
            <view class="reg-position {{reg.position === 'head' ? 'head' : 'body'}}">
              {{reg.position === 'head' ? '车头' : '车身'}}
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 官职报名统计 -->
  <view wx:if="{{selectedRegType === '官职报名' && selectedZone}}" class="card">
    <view class="stats-header">
      <view class="stats-title">{{selectedZone.zoneName}} 官职报名统计</view>
    </view>
    <view class="stats-actions">
      <button class="btn btn-danger btn-sm" bindtap="clearRegistrations">清空数据</button>
      <button class="btn btn-primary btn-sm" bindtap="saveScreenshot">保存截图</button>
    </view>

    <!-- 汇总数据 -->
    <view class="stats-summary">
      <view class="summary-item">
        <view class="summary-value">{{positionTotal}}</view>
        <view class="summary-label">总报名人数</view>
      </view>
      <view class="summary-item">
        <view class="summary-value">{{positionStats.length}}</view>
        <view class="summary-label">官职配置</view>
      </view>
    </view>

    <!-- 官职配置表格 -->
    <view wx:if="{{positionStats.length > 0}}" class="table-container">
      <view class="table-row table-header-row">
        <text class="table-cell">职位类型</text>
        <text class="table-cell">日期</text>
        <text class="table-cell">起始时间</text>
        <text class="table-cell">报名人数</text>
      </view>
      <view wx:for="{{positionStats}}" wx:key="*this" class="table-row">
        <text class="table-cell">{{item.config.positionType}}</text>
        <text class="table-cell">{{item.config.date}}</text>
        <text class="table-cell">{{item.config.startTime}}</text>
        <text class="table-cell">{{item.count}}人</text>
      </view>
    </view>

    <!-- 官职详情列表 -->
    <view class="time-slot-list">
      <view wx:for="{{positionStats}}" wx:key="*this" class="time-slot-card">
        <view class="slot-header">
          <view class="slot-time">
            <text class="config-title">{{item.config.positionType}}</text>
            <text class="slot-tag">{{item.config.date}}</text>
          </view>
          <view class="slot-status">
            {{item.count}}人报名
          </view>
        </view>
        <view class="slot-date">起始时间: {{item.config.startTime}}</view>

        <!-- 报名人员列表 -->
        <view wx:if="{{item.registrations.length > 0}}" class="registration-list">
          <view wx:for="{{item.registrations}}" wx:for-item="reg" wx:for-index="regIdx" wx:key="_id" class="registration-item">
            <view class="reg-order">{{regIdx + 1}}</view>
            <view class="reg-name">{{reg.nickName}}</view>
            <view class="reg-time">{{reg.timeSlot}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 兵工厂报名统计 -->
  <view wx:if="{{selectedRegType === '兵工厂报名' && selectedZone}}" class="card">
    <view class="stats-header">
      <view class="stats-title">{{selectedZone.zoneName}} 兵工厂报名统计</view>
    </view>
    <view class="stats-actions">
      <button class="btn btn-danger btn-sm" bindtap="clearRegistrations">清空数据</button>
      <button class="btn btn-primary btn-sm" bindtap="saveScreenshot">保存截图</button>
    </view>

    <!-- 汇总数据 -->
    <view class="stats-summary">
      <view class="summary-item">
        <view class="summary-value">{{arsenalTotal}}</view>
        <view class="summary-label">总报名人数</view>
      </view>
      <view class="summary-item">
        <view class="summary-value">{{arsenalStats.length}}</view>
        <view class="summary-label">活动配置</view>
      </view>
    </view>

    <!-- 兵工厂配置表格 -->
    <view wx:if="{{arsenalStats.length > 0}}" class="table-container">
      <view class="table-row table-header-row">
        <text class="table-cell">活动类型</text>
        <text class="table-cell">日期</text>
        <text class="table-cell">时间</text>
        <text class="table-cell">军团</text>
        <text class="table-cell">报名人数</text>
      </view>
      <view wx:for="{{arsenalStats}}" wx:key="*this" class="table-row">
        <text class="table-cell">{{item.config.activityType}}</text>
        <text class="table-cell">{{item.config.date}}</text>
        <text class="table-cell">{{item.config.timeValue}}</text>
        <text class="table-cell">{{item.config.corps}}</text>
        <text class="table-cell">{{item.count}}人</text>
      </view>
    </view>

    <!-- 兵工厂详情列表 -->
    <view class="time-slot-list">
      <view wx:for="{{arsenalStats}}" wx:key="*this" class="time-slot-card">
        <view class="slot-header">
          <view class="slot-time">
            <text class="config-title">{{item.config.activityType}}</text>
            <text class="slot-tag">{{item.config.date}}</text>
          </view>
          <view class="slot-status">
            {{item.count}}人报名
          </view>
        </view>
        <view class="slot-date">时间: {{item.config.timeValue}}  军团: {{item.config.corps}}</view>

        <!-- 报名人员列表 -->
        <view wx:if="{{item.registrations.length > 0}}" class="registration-list">
          <view wx:for="{{item.registrations}}" wx:for-item="reg" wx:for-index="regIdx" wx:key="_id" class="registration-item">
            <view class="reg-order">{{regIdx + 1}}</view>
            <view class="reg-name">{{reg.nickName}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 峡谷报名统计 -->
  <view wx:if="{{selectedRegType === '峡谷报名' && selectedZone}}" class="card">
    <view class="stats-header">
      <view class="stats-title">{{selectedZone.zoneName}} 峡谷报名统计</view>
    </view>
    <view class="stats-actions">
      <button class="btn btn-danger btn-sm" bindtap="clearRegistrations">清空数据</button>
      <button class="btn btn-primary btn-sm" bindtap="saveScreenshot">保存截图</button>
    </view>

    <!-- 汇总数据 -->
    <view class="stats-summary">
      <view class="summary-item">
        <view class="summary-value">{{canyonTotal}}</view>
        <view class="summary-label">总报名人数</view>
      </view>
      <view class="summary-item">
        <view class="summary-value">{{canyonStats.length}}</view>
        <view class="summary-label">活动配置</view>
      </view>
    </view>

    <!-- 峡谷配置表格 -->
    <view wx:if="{{canyonStats.length > 0}}" class="table-container">
      <view class="table-row table-header-row">
        <text class="table-cell">活动类型</text>
        <text class="table-cell">日期</text>
        <text class="table-cell">时间</text>
        <text class="table-cell">军团</text>
        <text class="table-cell">报名人数</text>
      </view>
      <view wx:for="{{canyonStats}}" wx:key="*this" class="table-row">
        <text class="table-cell">{{item.config.activityType}}</text>
        <text class="table-cell">{{item.config.date}}</text>
        <text class="table-cell">{{item.config.timeValue}}</text>
        <text class="table-cell">{{item.config.corps}}</text>
        <text class="table-cell">{{item.count}}人</text>
      </view>
    </view>

    <!-- 峡谷详情列表 -->
    <view class="time-slot-list">
      <view wx:for="{{canyonStats}}" wx:key="*this" class="time-slot-card">
        <view class="slot-header">
          <view class="slot-time">
            <text class="config-title">{{item.config.activityType}}</text>
            <text class="slot-tag">{{item.config.date}}</text>
          </view>
          <view class="slot-status">
            {{item.count}}人报名
          </view>
        </view>
        <view class="slot-date">时间: {{item.config.timeValue}}  军团: {{item.config.corps}}</view>

        <!-- 报名人员列表 -->
        <view wx:if="{{item.registrations.length > 0}}" class="registration-list">
          <view wx:for="{{item.registrations}}" wx:for-item="reg" wx:for-index="regIdx" wx:key="_id" class="registration-item">
            <view class="reg-order">{{regIdx + 1}}</view>
            <view class="reg-name">{{reg.nickName}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>