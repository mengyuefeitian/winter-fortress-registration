/* pages/superAdmin/admin-review/admin-review.wxss */

.admin-review-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16px;
}

.empty-state {
  padding: 40px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #999999;
}

.application-list {
  display: flex;
  flex-direction: column;
}

.application-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.application-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.applicant-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  margin-right: 12px;
}

.applicant-info {
  flex: 1;
}

.applicant-name {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4px;
}

.applicant-phone {
  font-size: 14px;
  color: #666666;
}

.application-time {
  font-size: 12px;
  color: #999999;
  margin-bottom: 12px;
}

.application-actions {
  display: flex;
  justify-content: space-between;
}

.approve-btn,
.reject-btn {
  font-size: 14px;
  padding: 10px 20px;
  border-radius: 6px;
  flex: 1;
  margin-right: 8px;
}

.approve-btn:last-child,
.reject-btn:last-child {
  margin-right: 0;
}

.approve-btn {
  background-color: #52C41A;
  color: #FFFFFF;
}

.reject-btn {
  background-color: transparent;
  color: #FF6B6B;
  border: 1px solid #FF6B6B;
}

.reviewed-list {
  display: flex;
  flex-direction: column;
}

.reviewed-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 8px;
}

.reviewed-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.reviewed-name {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
}

.reviewed-status {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
}

.reviewed-status.approved {
  background-color: #E8FFE8;
  color: #52C41A;
}

.reviewed-status.rejected {
  background-color: #FFE8E8;
  color: #FF6B6B;
}

.reviewed-phone {
  font-size: 12px;
  color: #666666;
  margin-bottom: 4px;
}

.reviewed-time {
  font-size: 12px;
  color: #999999;
}