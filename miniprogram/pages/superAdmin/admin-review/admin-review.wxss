/* pages/superAdmin/admin-review/admin-review.wxss */

.page {
  padding: 10px;
  #removed-bg
  min-height: 100vh;
}

.section-header {
  margin: 8px 2px 6px;
}

.section-title {
  font-size: 14px;
  font-weight: 500;
  color: #666;
}

.empty-state {
  padding: 16px;
  text-align: center;
}

.empty-text {
  font-size: 13px;
  color: #999;
}

/* 申请人分区信息 */
.applicant-zone-info {
  margin-bottom: 8px;
  padding: 6px 8px;
  background-color: #E8F4FD;
  border-radius: 4px;
}

/* 卡片样式 - 最紧凑布局 */
.card {
  width: 100%;
  background-color: #FFF;
  border-radius: 4px;
  padding: 8px 10px;
  margin-bottom: 8px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
}

.card-body {
  display: flex;
  flex-direction: column;
}

/* 申请/审核时间 */
.application-time {
  padding-bottom: 4px;
  border-bottom: 1px solid #EEE;
  margin-bottom: 6px;
}

.card-footer {
  display: flex;
  gap: 6px;
  padding-top: 6px;
  margin-top: 6px;
  border-top: 1px solid #EEE;
}

.avatar {
  width: 28px;
  height: 28px;
  border-radius: 14px;
}

.ml-10 {
  margin-left: 10px;
}

.mt-2 {
  margin-top: 2px;
}

.mt-4 {
  margin-top: 4px;
}

.mt-6 {
  margin-top: 6px;
}

.mt-24 {
  margin-top: 16px;
}

.text-sm {
  font-size: 13px;
}

.text-xs {
  font-size: 11px;
}

.font-medium {
  font-weight: 500;
}

.text-secondary {
  color: #666;
}

.text-weak {
  color: #999;
}

.text-danger {
  color: #FA5151;
}

.text-primary {
  color: #4A90D9;
}

.custom-name-hint {
  margin-top: 6px;
  padding: 4px 8px;
  background-color: #F0F4FA;
  border-radius: 4px;
}

.invalid-warning {
  padding: 4px 8px;
  background-color: #FFF1F0;
  border-radius: 2px;
}

.flex {
  display: flex;
}

.items-center {
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.gap-4 {
  gap: 4px;
}

/* 用户信息行 - 昵称和标签在同一行完美对齐 */
.user-info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6px;
}

.user-name {
  font-size: 13px;
  font-weight: 500;
  line-height: 18px;
}

/* 标签样式 - 文字完美居中 */
.tag {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  padding: 0 6px;
  height: 18px;
  border-radius: 2px;
}

.tag-default {
  background-color: #F0F0F0;
  color: #666;
}

.tag-success {
  background-color: #E8F5E8;
  color: #52C41A;
}

.tag-danger {
  background-color: #FFF1F0;
  color: #FA5151;
}

.tag-primary {
  background-color: #E6F7E6;
  color: #52C41A;
}

/* 按钮样式 - 文字居中 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  height: 26px;
  line-height: 1;
  padding: 0;
  border-radius: 4px;
  border: none;
  flex: 1;
}

.btn-success {
  background-color: #52C41A;
  color: #FFF;
}

.btn-danger {
  background-color: #FA5151;
  color: #FFF;
}

.btn-ghost {
  background-color: #F0F0F0;
  color: #666;
}

/* 分区选择 */
.zone-select-section {
  padding-top: 6px;
  margin-top: 6px;
  border-top: 1px solid #EEE;
}

.zone-creation-section {
  padding-top: 6px;
  margin-top: 6px;
  border-top: 1px solid #EEE;
}

.zone-creation-form {
  margin-top: 8px;
}

.creation-row {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.creation-label {
  font-size: 12px;
  color: #666;
  width: 60px;
  flex-shrink: 0;
}

.creation-input {
  flex: 1;
  height: 32px;
  background-color: #F5F5F5;
  border: 1px solid #E5E5E5;
  border-radius: 4px;
  padding: 0 10px;
  font-size: 14px;
}

.select-label {
  font-size: 12px;
  color: #666;
  margin-bottom: 4px;
}

.select-actions {
  display: flex;
  gap: 6px;
  margin-top: 6px;
}

/* 功能网格 */
.function-grid {
  display: flex;
  flex-direction: column;
}

/* ===== Dark Theme Override ===== */
.page, .alliance-config-container, .zone-manage-container,
.alliance-manage-container, .auto-clear-container, .phone-manage-container {
  background: transparent !important;
  color: #F8FAFC;
}
.section, .card, .time-slot-card, .member-card, .review-item,
.stat-card, .stat-section, .alliance-card, .zone-card,
.auditor-section, .config-card, .review-card, .phone-card,
.identity-card, .auto-clear-card {
  background-color: rgba(255,255,255,0.07) !important;
  border: 1px solid rgba(255,255,255,0.13) !important;
}
.section-title, .card-title, .form-label, .zone-name, .alliance-name,
.member-name, .user-name, .stat-label, .config-label,
.page-title, .review-status, .phone-label {
  color: #F8FAFC !important;
}
.section-desc, .zone-desc, .member-role, .stat-value,
.text-weak, .text-secondary, .sub-text, .review-desc, .config-desc {
  color: #94A3B8 !important;
}
.edit-input, .form-input, .search-input, .input {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.picker-compact, .picker-value {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.alliance-index, .alliance-header {
  background-color: rgba(56,189,248,0.12) !important;
  color: #38BDF8 !important;
  border-color: rgba(56,189,248,0.2) !important;
}
.status-tag, .status-badge, .tag, .role-tag {
  opacity: 0.9;
}
.divider, .card-divider, .section-divider {
  border-color: rgba(255,255,255,0.1) !important;
}

