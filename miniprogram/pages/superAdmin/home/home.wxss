/* pages/superAdmin/home/home.wxss */

.super-admin-home-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.header-section {
  background: linear-gradient(135deg, #4A90D9 0%, #3A80C9 100%);
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 20px;
}

.header-title {
  font-size: 24px;
  font-weight: 500;
  color: #FFFFFF;
  margin-bottom: 8px;
}

.header-desc {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

.function-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

.function-card {
  width: calc(50% - 8px);
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 20px 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  margin-right: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.3s ease;
}

.function-card:nth-child(2n) {
  margin-right: 0;
}

.function-card:active {
  transform: scale(0.98);
  background-color: #F0F7FF;
}

.function-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 12px;
}

.function-name {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8px;
}

.function-desc {
  font-size: 12px;
  color: #999999;
  text-align: center;
}

.badge {
  position: absolute;
  top: 8px;
  right: 8px;
  background-color: #FF6B6B;
  color: #FFFFFF;
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 12px;
}

.overview-section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.overview-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16px;
}

.overview-grid {
  display: flex;
  justify-content: space-around;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px;
}

.overview-value {
  font-size: 24px;
  font-weight: 500;
  color: #4A90D9;
  margin-bottom: 8px;
}

.overview-label {
  font-size: 12px;
  color: #999999;
}