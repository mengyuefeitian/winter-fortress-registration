<view class="page">
  <view class="card mt-16">
    <view class="card-body flex items-center">
      <image class="avatar-lg" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="ml-16 flex-1">
        <text class="text-lg font-semibold">{{userInfo.nickName || '未登录'}}</text>
        <view class="flex items-center mt-8">
          <view class="status-dot status-active"></view>
          <text class="text-secondary">{{roleDisplayName}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 配置管理 -->
  <view class="section-header">
    <text class="section-title">配置管理</text>
  </view>
  <view class="function-grid">
    <view class="function-card-compact" bindtap="goToZoneManage">
      <view class="function-content">
        <text class="function-name">分区管理</text>
        <text class="function-desc">创建和管理分区</text>
      </view>
    </view>
    <view class="function-card-compact" bindtap="goToAllianceManage">
      <view class="function-content">
        <text class="function-name">联盟管理</text>
        <text class="function-desc">管理所有联盟</text>
      </view>
    </view>
    <view class="function-card-compact" bindtap="goToTimeSlotConfig">
      <view class="function-content">
        <text class="function-name">时间段配置</text>
        <text class="function-desc">配置堡垒活动时间</text>
      </view>
    </view>
    <view class="function-card-compact" bindtap="goToPositionManage">
      <view class="function-content">
        <text class="function-name">官职管理</text>
        <text class="function-desc">创建官职报名配置</text>
      </view>
    </view>
    <view class="function-card-compact" bindtap="goToBattleConfig">
      <view class="function-content">
        <text class="function-name">国战报名</text>
        <text class="function-desc">管理国战日期与报名</text>
      </view>
    </view>
  </view>

  <!-- 兵工厂&峡谷 -->
  <view class="section-header mt-24">
    <text class="section-title">兵工厂&峡谷</text>
  </view>
  <view class="function-grid">
    <view class="function-card-compact" bindtap="goToArsenalConfig">
      <view class="function-content">
        <text class="function-name">活动配置</text>
        <text class="function-desc">生成联盟活动时间进行报名</text>
      </view>
    </view>
  </view>

  <!-- 权限审核 -->
  <view class="section-header mt-24">
    <text class="section-title">权限审核</text>
  </view>
  <view class="function-grid">
    <view class="function-card-compact" bindtap="goToAdminReview">
      <view class="function-content">
        <text class="function-name">区管审核</text>
        <text class="function-desc">审核区管申请</text>
      </view>
      <view wx:if="{{pendingZoneManagerCount > 0}}" class="badge badge-danger">{{pendingZoneManagerCount}}</view>
    </view>
    <view class="function-card-compact" bindtap="goToAllianceManagerReview">
      <view class="function-content">
        <text class="function-name">盟管审核</text>
        <text class="function-desc">审核盟管申请</text>
      </view>
      <view wx:if="{{pendingAllianceManagerCount > 0}}" class="badge badge-danger">{{pendingAllianceManagerCount}}</view>
    </view>
    <view class="function-card-compact" bindtap="goToZoneCreationReview">
      <view class="function-content">
        <text class="function-name">分区开通审核</text>
        <text class="function-desc">审核用户分区开通申请</text>
      </view>
      <view wx:if="{{pendingZoneCreationCount > 0}}" class="badge badge-danger">{{pendingZoneCreationCount}}</view>
    </view>
    <view class="function-card-compact" bindtap="goToPhoneManage">
      <view class="function-content">
        <text class="function-name">超管管理</text>
        <text class="function-desc">设置超管手机号</text>
      </view>
    </view>
    <view class="function-card-compact" bindtap="goToMemberManage">
      <view class="function-content">
        <text class="function-name">成员管理</text>
        <text class="function-desc">查看和管理区管盟管</text>
      </view>
    </view>
    <view class="function-card-compact" bindtap="goToUserIdentity">
      <view class="function-content">
        <text class="function-name">用户身份管理</text>
        <text class="function-desc">查看用户分区归属、添加区管</text>
      </view>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="section-header mt-24">
    <text class="section-title">统计数据</text>
  </view>
  <view class="function-grid">
    <view class="function-card-compact" bindtap="goToAllStats">
      <view class="function-content">
        <text class="function-name">全局统计</text>
        <text class="function-desc">查看全局数据</text>
      </view>
    </view>
    <view class="function-card-compact" bindtap="goToAutoClear">
      <view class="function-content">
        <text class="function-name">自动清理配置</text>
        <text class="function-desc">定时清空报名</text>
      </view>
    </view>
  </view>
</view>