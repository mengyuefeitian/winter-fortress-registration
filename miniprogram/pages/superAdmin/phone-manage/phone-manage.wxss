/* pages/superAdmin/phone-manage/phone-manage.wxss */

.phone-manage-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16px;
}

.form-card {
  padding: 16px;
  background-color: #F5F7FA;
  border-radius: 8px;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #666666;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 40px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
}

.add-btn {
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
  width: 100%;
}

.empty-state {
  padding: 40px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #999999;
}

.admin-list {
  display: flex;
  flex-direction: column;
}

.admin-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.admin-phone {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.admin-status {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
}

.admin-status.bound {
  background-color: #E8FFE8;
  color: #52C41A;
}

.admin-status.unbound {
  background-color: #FFF7E8;
  color: #FF9800;
}

.admin-name {
  font-size: 12px;
  color: #666666;
  margin-bottom: 8px;
}

.admin-actions {
  display: flex;
  justify-content: flex-end;
}

.delete-btn {
  background-color: transparent;
  color: #FF6B6B;
  border: 1px solid #FF6B6B;
  font-size: 12px;
  padding: 8px 16px;
  border-radius: 6px;
}