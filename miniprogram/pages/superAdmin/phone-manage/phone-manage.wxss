/* pages/superAdmin/phone-manage/phone-manage.wxss */

.phone-manage-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8px;
}

.section-desc {
  font-size: 12px;
  color: #999999;
  margin-bottom: 16px;
}

.form-card {
  padding: 16px;
  background-color: #F5F7FA;
  border-radius: 8px;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #666666;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 40px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
}

.add-btn {
  background-color: #07C160;
  color: #FFFFFF;
  border-radius: 6px;
  padding: 0 16px;
  height: 36px;
  line-height: 36px;
  font-size: 14px;
  width: auto;
  margin-top: 8px;
  box-sizing: border-box;
}

.empty-state {
  padding: 40px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #999999;
}

.admin-list {
  display: flex;
  flex-direction: column;
}

.admin-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.admin-phone {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.admin-status {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
}

.admin-status.bound {
  background-color: #E8FFE8;
  color: #52C41A;
}

.admin-status.unbound {
  background-color: #FFF7E8;
  color: #FF9800;
}

.admin-name {
  font-size: 12px;
  color: #666666;
  margin-bottom: 8px;
}

.admin-actions {
  display: flex;
  justify-content: flex-end;
}

.delete-btn {
  background-color: transparent;
  color: #FA5151;
  border: 1px solid #FA5151;
  font-size: 12px;
  padding: 0 16px;
  height: 28px;
  line-height: 28px;
  border-radius: 6px;
  box-sizing: border-box;
}

/* 用户身份管理样式 */
.user-list {
  display: flex;
  flex-direction: column;
}

.user-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.user-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: #E8E8E8;
  margin-right: 10px;
  flex-shrink: 0;
}

.user-details {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 2px;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 6px;
}

.user-phone {
  font-size: 11px;
  color: #999999;
}

.user-role-tag {
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 3px;
  color: #FFFFFF;
}

.role-user {
  background-color: #C0C0C0;
}

.role-auditor {
  background-color: #576B95;
}

.role-admin {
  background-color: #4A90D9;
}

.role-superAdmin {
  background-color: #FA5151;
}

.reset-btn-sm {
  font-size: 11px;
  color: #FA5151;
  padding: 3px 8px;
  border: 1px solid #FA5151;
  border-radius: 4px;
  flex-shrink: 0;
  margin-left: 8px;
}

.reset-btn-sm:active {
  background-color: #FA5151;
  color: #FFFFFF;
}

/* 搜索框样式 */
.search-box {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}

.search-input {
  flex: 1;
  height: 40px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
}

.search-btn {
  background-color: #576B95;
  color: #FFFFFF;
  font-size: 14px;
  padding: 0 16px;
  height: 40px;
  line-height: 40px;
  border-radius: 6px;
}

.search-result {
  margin-bottom: 16px;
}

.result-card {
  background-color: #FFF7E6;
  border-radius: 8px;
  padding: 16px;
  border: 1px solid #FFB366;
}

.result-info {
  margin-bottom: 8px;
}

.result-label {
  font-size: 12px;
  color: #999999;
}

.result-name {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.result-detail {
  font-size: 12px;
  color: #666666;
  margin-bottom: 4px;
}

.result-detail text {
  word-break: break-all;
}