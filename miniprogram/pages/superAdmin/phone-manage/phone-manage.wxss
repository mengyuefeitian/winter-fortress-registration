/* pages/superAdmin/phone-manage/phone-manage.wxss */

.phone-manage-container {
  padding: 20px;
  #removed-bg
  min-height: 100vh;
}

.section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8px;
}

.section-desc {
  font-size: 12px;
  color: #999999;
  margin-bottom: 16px;
}

.form-card {
  padding: 16px;
  background-color: #F5F7FA;
  border-radius: 8px;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #666666;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 40px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
}

.add-btn {
  background-color: #07C160;
  color: #FFFFFF;
  border-radius: 6px;
  padding: 0 16px;
  height: 36px;
  line-height: 36px;
  font-size: 14px;
  width: auto;
  margin-top: 8px;
  box-sizing: border-box;
}

.empty-state {
  padding: 40px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #999999;
}

.admin-list {
  display: flex;
  flex-direction: column;
}

.admin-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.admin-phone {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.admin-status {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
}

.admin-status.bound {
  background-color: #E8FFE8;
  color: #52C41A;
}

.admin-status.unbound {
  background-color: #FFF7E8;
  color: #FF9800;
}

.admin-name {
  font-size: 12px;
  color: #666666;
  margin-bottom: 8px;
}

.admin-actions {
  display: flex;
  justify-content: flex-end;
}

.delete-btn {
  background-color: transparent;
  color: #FA5151;
  border: 1px solid #FA5151;
  font-size: 12px;
  padding: 0 16px;
  height: 28px;
  line-height: 28px;
  border-radius: 6px;
  box-sizing: border-box;
}

/* 用户身份管理样式 */
.user-list {
  display: flex;
  flex-direction: column;
}

.user-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.user-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: #E8E8E8;
  margin-right: 10px;
  flex-shrink: 0;
}

.user-details {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 2px;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 6px;
}

.user-phone {
  font-size: 11px;
  color: #999999;
}

.user-role-tag {
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 3px;
  color: #FFFFFF;
}

.role-user {
  background-color: #C0C0C0;
}

.role-auditor {
  background-color: #576B95;
}

.role-admin {
  background-color: #4A90D9;
}

.role-superAdmin {
  background-color: #FA5151;
}

.reset-btn-sm {
  font-size: 11px;
  color: #FA5151;
  padding: 3px 8px;
  border: 1px solid #FA5151;
  border-radius: 4px;
  flex-shrink: 0;
  margin-left: 8px;
}

.reset-btn-sm:active {
  background-color: #FA5151;
  color: #FFFFFF;
}

/* 搜索框样式 */
.search-box {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}

.search-input {
  flex: 1;
  height: 40px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
}

.search-btn {
  background-color: #576B95;
  color: #FFFFFF;
  font-size: 14px;
  padding: 0 16px;
  height: 40px;
  line-height: 40px;
  border-radius: 6px;
}

.search-result {
  margin-bottom: 16px;
}

.result-card {
  background-color: #FFF7E6;
  border-radius: 8px;
  padding: 16px;
  border: 1px solid #FFB366;
}

.result-info {
  margin-bottom: 8px;
}

.result-label {
  font-size: 12px;
  color: #999999;
}

.result-name {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.result-detail {
  font-size: 12px;
  color: #666666;
  margin-bottom: 4px;
}

.result-detail text {
  word-break: break-all;
}

/* 分页加载样式 */
.list-header {
  font-size: 12px;
  color: #999999;
  margin-bottom: 8px;
  padding: 8px 0;
}

.load-more {
  padding: 16px;
  text-align: center;
}

.load-more-btn {
  background-color: #576B95;
  color: #FFFFFF;
  font-size: 14px;
  padding: 0 24px;
  height: 36px;
  line-height: 36px;
  border-radius: 6px;
}

.load-more-btn[disabled] {
  background-color: #C0C0C0;
  color: #FFFFFF;
}

.list-footer {
  padding: 16px;
  text-align: center;
  font-size: 12px;
  color: #999999;
}

/* 搜索结果样式 */
.search-results {
  margin-bottom: 16px;
}

.result-count {
  font-size: 12px;
  color: #666666;
  margin-bottom: 8px;
  padding: 8px 0;
}

.clear-btn {
  background-color: #C0C0C0;
  color: #FFFFFF;
  font-size: 14px;
  padding: 0 12px;
  height: 40px;
  line-height: 40px;
  border-radius: 6px;
}

.mt-16 {
  margin-top: 16px;
}

/* ===== Dark Theme Override ===== */
.page, .alliance-config-container, .zone-manage-container,
.alliance-manage-container, .auto-clear-container, .phone-manage-container {
  background: transparent !important;
  color: #F8FAFC;
}
.section, .card, .time-slot-card, .member-card, .review-item,
.stat-card, .stat-section, .alliance-card, .zone-card,
.auditor-section, .config-card, .review-card, .phone-card,
.identity-card, .auto-clear-card {
  background-color: rgba(255,255,255,0.07) !important;
  border: 1px solid rgba(255,255,255,0.13) !important;
}
.section-title, .card-title, .form-label, .zone-name, .alliance-name,
.member-name, .user-name, .stat-label, .config-label,
.page-title, .review-status, .phone-label {
  color: #F8FAFC !important;
}
.section-desc, .zone-desc, .member-role, .stat-value,
.text-weak, .text-secondary, .sub-text, .review-desc, .config-desc {
  color: #94A3B8 !important;
}
.edit-input, .form-input, .search-input, .input {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.picker-compact, .picker-value {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.alliance-index, .alliance-header {
  background-color: rgba(56,189,248,0.12) !important;
  color: #38BDF8 !important;
  border-color: rgba(56,189,248,0.2) !important;
}
.status-tag, .status-badge, .tag, .role-tag {
  opacity: 0.9;
}
.divider, .card-divider, .section-divider {
  border-color: rgba(255,255,255,0.1) !important;
}

