<!--pages/superAdmin/phone-manage/phone-manage.wxml-->
<view class="phone-manage-container">
  <!-- 添加超管手机号 -->
  <view class="section">
    <view class="section-title">添加超级管理员</view>
    <view class="form-card">
      <view class="form-item">
        <view class="form-label">手机号</view>
        <input class="form-input" placeholder="请输入手机号" value="{{newPhone}}" bindinput="onPhoneInput" type="number" maxlength="11" />
      </view>
      <button class="add-btn" bindtap="addSuperAdminPhone">添加</button>
    </view>
  </view>

  <!-- 超管列表 -->
  <view class="section">
    <view class="section-title">超级管理员列表</view>

    <view wx:if="{{superAdmins.length === 0}}" class="empty-state">
      <view class="empty-text">暂无超级管理员</view>
    </view>

    <view wx:else class="admin-list">
      <view wx:for="{{superAdmins}}" wx:key="_id" class="admin-card">
        <view class="admin-header">
          <view class="admin-phone">{{item.phone}}</view>
          <view class="admin-status {{item.userId ? 'bound' : 'unbound'}}">
            {{item.userId ? '已绑定用户' : '未绑定用户'}}
          </view>
        </view>
        <view wx:if="{{item.nickName}}" class="admin-name">用户: {{item.nickName}}</view>
        <view class="admin-actions">
          <button class="delete-btn" bindtap="deleteSuperAdmin" data-id="{{item._id}}" data-index="{{index}}">删除</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 用户身份重置 -->
  <view class="section">
    <view class="section-title">用户身份管理</view>
    <view class="section-desc">重置用户身份将清空其绑定的手机号，用户需要重新登录并绑定手机号</view>

    <!-- 模糊搜索 -->
    <view class="search-box">
      <input class="search-input" placeholder="搜索昵称或手机号" value="{{searchKeyword}}" bindinput="onSearchKeywordInput" bindconfirm="doSearch" confirm-type="search" />
      <button class="search-btn" bindtap="doSearch">搜索</button>
      <button wx:if="{{searchMode}}" class="clear-btn" bindtap="clearSearchKeyword">清除</button>
    </view>

    <!-- 搜索结果 -->
    <view wx:if="{{searchMode}}" class="search-results">
      <view class="result-count">找到 {{searchResults.length}} 个用户</view>
      <view wx:if="{{searchResults.length === 0}}" class="empty-state">
        <view class="empty-text">未找到匹配的用户</view>
      </view>
      <view wx:else class="user-list">
        <view wx:for="{{searchResults}}" wx:key="_id" class="user-card">
          <view class="user-info">
            <image class="user-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}"></image>
            <view class="user-details">
              <view class="user-name">{{item.nickName}}</view>
              <view class="user-meta">
                <text wx:if="{{item.phone}}" class="user-phone">{{item.phone}}</text>
                <text class="user-role-tag role-{{item.role}}">{{item.role === 'superAdmin' ? '超管' : (item.role === 'admin' ? '区管' : (item.role === 'auditor' ? '盟管' : '用户'))}}</text>
              </view>
            </view>
          </view>
          <view wx:if="{{item.phone}}" class="reset-btn-sm" catchtap="resetUserIdentity" data-id="{{item._id}}" data-index="{{index}}">重置</view>
        </view>
      </view>
    </view>

    <!-- 按手机号精确查找 -->
    <view wx:if="{{!searchMode}}" class="search-box mt-16">
      <input class="search-input" placeholder="输入完整手机号查找" value="{{searchPhone}}" bindinput="onSearchPhoneInput" type="number" maxlength="11" />
      <button class="search-btn" bindtap="searchByPhone">查找</button>
    </view>

    <view wx:if="{{!searchMode && searchResult}}" class="search-result">
      <view class="result-card">
        <view class="result-info">
          <text class="result-label">找到用户：</text>
          <text class="result-name">{{searchResult.nickName}}</text>
        </view>
        <view class="result-detail">
          <text>手机号：{{searchResult.phone}}</text>
        </view>
        <view class="result-detail">
          <text>微信ID：{{searchResult.openid}}</text>
        </view>
        <button class="reset-btn" bindtap="resetSearchUser" data-id="{{searchResult._id}}">清空此用户手机号绑定</button>
      </view>
    </view>

    <!-- 用户列表（分页） -->
    <view wx:if="{{!searchMode && !searchResult}}">
      <view class="list-header">
        <text>已绑定手机号用户 ({{usersTotal}}人)</text>
      </view>

      <view wx:if="{{users.length === 0}}" class="empty-state">
        <view class="empty-text">暂无绑定手机号的用户</view>
      </view>

      <view wx:else class="user-list">
        <view wx:for="{{users}}" wx:key="_id" class="user-card">
          <view class="user-info">
            <image class="user-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}"></image>
            <view class="user-details">
              <view class="user-name">{{item.nickName}}</view>
              <view class="user-meta">
                <text class="user-phone">{{item.phone}}</text>
                <text class="user-role-tag role-{{item.role}}">{{item.role === 'superAdmin' ? '超管' : (item.role === 'admin' ? '区管' : (item.role === 'auditor' ? '盟管' : '用户'))}}</text>
              </view>
            </view>
          </view>
          <view class="reset-btn-sm" catchtap="resetUserIdentity" data-id="{{item._id}}" data-index="{{index}}">重置</view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{hasMoreUsers}}" class="load-more">
        <button class="load-more-btn" bindtap="loadMoreUsers" disabled="{{usersLoading}}">
          {{usersLoading ? '加载中...' : '加载更多'}}
        </button>
      </view>
      <view wx:elif="{{users.length > 0}}" class="list-footer">
        <text>已显示全部 {{users.length}} 位用户</text>
      </view>
    </view>
  </view>
</view>