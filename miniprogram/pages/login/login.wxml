<!--pages/login/login.wxml - Winter Fortress Redesign-->
<view class="login-container">
  <view class="login-header">
    <view class="title">❄️ 冬日堡垒</view>
    <view class="desc">联盟活动报名系统</view>
  </view>

  <view class="login-content">
    <!-- 隐私协议 -->
    <view class="wf-card privacy-section">
      <view class="privacy-check" bindtap="togglePrivacy">
        <view class="checkbox {{privacyAgreed ? 'checked' : ''}}">
          <view class="checkbox-icon" wx:if="{{privacyAgreed}}">✓</view>
        </view>
        <view class="privacy-text">
          我已阅读并同意
          <text class="privacy-link" catchtap="openPrivacyContract">《隐私保护指引》</text>
        </view>
      </view>
    </view>

    <!-- 身份信息设置 -->
    <view wx:if="{{userInfoLoaded}}" class="auth-section">
      <view class="wf-card auth-card">
        <view class="auth-title">指挥官身份认证</view>

        <!-- 头像和昵称 -->
        <view class="auth-buttons">
          <button class="avatar-btn wf-input flex-center {{tempAvatarUrl ? 'completed' : ''}}" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image class="avatar-img" src="{{tempAvatarUrl || '/images/default-avatar.png'}}"></image>
            <view class="btn-label">{{tempAvatarUrl ? '已设置头像' : '点击选择头像'}}</view>
          </button>

          <view class="nickname-box wf-input {{tempNickName ? 'completed' : ''}}">
            <input class="nickname-input" placeholder="输入游戏昵称" value="{{tempNickName}}" bindinput="onNicknameInputing" maxlength="12" />
          </view>
        </view>

        <!-- 使用微信昵称 -->
        <view class="quick-nickname">
          <view class="wx-nickname-box">
            <input class="wx-nickname-input wf-input" type="nickname" placeholder="一键获取微信昵称" bindinput="onUseWxNicknameInput" />
          </view>
        </view>
      </view>
    </view>

    <!-- 完成登录 -->
    <view class="complete-section">
      <button class="login-btn wf-btn {{!tempAvatarUrl || !tempNickName || !privacyAgreed ? 'disabled' : ''}}" bindtap="completeLogin" disabled="{{!tempAvatarUrl || !tempNickName || !privacyAgreed}}">进入堡垒</button>
      <view class="login-tip">登录后即可参与冬季演习报名</view>
    </view>
  </view>
</view>
