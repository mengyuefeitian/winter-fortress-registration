/* pages/login/login.wxss - Winter Fortress Style */
.login-container {
  min-height: 100vh;
  padding: 40px 24px;
  display: flex;
  flex-direction: column;
}

.login-header {
  text-align: center;
  margin-bottom: 40px;
  margin-top: 60px;
}

.login-header .title {
  font-size: 32px;
  font-weight: 800;
  color: var(--wf-text-main);
  text-shadow: 0 0 20px rgba(56, 189, 248, 0.4);
  margin-bottom: 8px;
}

.login-header .desc {
  font-size: 14px;
  color: var(--wf-text-sub);
  letter-spacing: 2px;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.privacy-section {
  margin-bottom: 20px;
  padding: 12px;
}

.privacy-check {
  display: flex;
  align-items: center;
  gap: 8px;
}

.checkbox {
  width: 18px;
  height: 18px;
  border: 1px solid var(--wf-border);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: var(--wf-primary);
  border-color: var(--wf-primary);
}

.checkbox-icon {
  font-size: 12px;
  color: #fff;
}

.privacy-text {
  font-size: 12px;
  color: var(--wf-text-sub);
  line-height: 1.4;
}

.privacy-link {
  color: var(--wf-primary);
}

.auth-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 16px;
  color: var(--wf-text-main);
}

.auth-buttons {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.avatar-btn {
  display: flex !important;
  align-items: center;
  gap: 12px;
  padding: 8px 12px;
  background: transparent;
  border: none;
}

.avatar-btn::after { border: none; }

.avatar-img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 2px solid var(--wf-border);
}

.btn-label {
  font-size: 14px;
  color: var(--wf-text-main);
}

.nickname-box {
  padding: 0;
  display: flex;
  align-items: center;
}

.nickname-input {
  background: transparent;
  border: none;
  color: var(--wf-text-main);
  font-size: 15px;
  width: 100%;
}

.quick-nickname {
  margin-top: 12px;
}

.wx-nickname-input {
  margin-bottom: 0;
}

.complete-section {
  margin-top: auto;
  padding-bottom: 20px;
}

.login-btn.disabled {
  opacity: 0.5;
  background: #333;
  box-shadow: none;
}

.login-tip {
  text-align: center;
  font-size: 12px;
  color: var(--wf-text-sub);
  margin-top: 16px;
}
