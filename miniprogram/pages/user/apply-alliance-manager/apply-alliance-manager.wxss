/* pages/user/apply-alliance-manager/apply-alliance-manager.wxss */
.page {
  padding: 12px;
  background-color: #F6F6F6;
  min-height: 100vh;
}

.card {
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

.zone-info-row {
  display: flex;
  align-items: center;
  padding: 8px 0;
}

.form-label {
  font-size: 13px;
  color: #5F5F5F;
  margin-bottom: 4px;
  display: block;
}

.zone-name-text {
  font-size: 14px;
  font-weight: 500;
  color: #000000;
}

.picker-view {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 4px;
  padding: 8px 12px;
  height: 32px;
  font-size: 14px;
  color: #000000;
}

.picker-view.disabled {
  background-color: #F0F0F0;
}

.picker-placeholder {
  color: #A6A6A6;
}

.form-item {
  margin-bottom: 12px;
}

.form-input {
  width: 100%;
  height: 36px;
  background-color: #F5F5F5;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
  border: 1px solid #E5E5E5;
  box-sizing: border-box;
}

.input-hint {
  font-size: 12px;
  color: #A6A6A6;
  margin-top: 4px;
  display: block;
}

.btn {
  font-size: 15px;
  border-radius: 6px;
  padding: 0 16px;
  height: 44px;
  line-height: 44px;
  border: none;
  box-sizing: border-box;
}

.btn-primary {
  background-color: #07C160;
  color: #FFFFFF;
}

.btn-full {
  width: 100%;
  margin-top: 8px;
}

.btn-primary:active {
  background-color: #06AD56;
}

.btn[disabled] {
  background-color: #A6A6A6;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.section-title {
  font-size: 15px;
  font-weight: 500;
  color: #5F5F5F;
}

.tip-text {
  font-size: 13px;
  color: #5F5F5F;
  line-height: 1.6;
  display: block;
}

.empty-tip {
  text-align: center;
  padding: 16px;
  color: #999999;
  font-size: 13px;
}
