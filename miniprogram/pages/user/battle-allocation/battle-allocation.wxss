/* pages/user/battle-allocation/battle-allocation.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #0F172A;
}

.header {
  text-align: center;
  padding: 20rpx 0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  display: block;
}

.date {
  font-size: 28rpx;
  color: #4A90D9;
  margin-top: 8rpx;
  display: block;
}

.table-wrapper {
  background: #fff;
  border-radius: 12rpx;
  overflow-x: auto;
  margin-top: 20rpx;
}

.table-header {
  display: flex;
  background: #4A90D9;
  color: #fff;
  font-size: 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  min-width: 500rpx;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 24rpx;
  min-width: 500rpx;
}

.table-row:nth-child(even) {
  background: #0F172A;
}

.col {
  padding: 16rpx 8rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60rpx;
}

.col-head { width: 140rpx; font-weight: bold; }
.col-body { flex: 1; min-width: 250rpx; text-align: left; justify-content: flex-start; }

.mobile-label {
  color: #FF9800;
}

.empty-row {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.action-bar {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding: 0 20rpx;
}

.btn {
  padding: 16rpx 30rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #fff;
}

.btn-save {
  background: #52C41A;
}
