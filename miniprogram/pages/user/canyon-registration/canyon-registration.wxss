/* pages/user/canyon-registration/canyon-registration.wxss */

/* 复用兵工厂报名页面样式，保持一致的展示效果 */
@import "../arsenal-registration/arsenal-registration.wxss";

/* 位置选项样式覆盖 - 参战/替补 */
.position-option.active {
  background-color: #07C160;
  border-color: #07C160;
}

.position-option.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 报名位置标签 - 参战/替补 */
.registration-position.combat {
  background-color: #FFE8E8;
  color: #FA5151;
}

.registration-position.substitute {
  background-color: #F0FFF0;
  color: #07C160;
}

/* ===== Dark Theme Overrides ===== */
.canyon-container {
  min-height: 100vh;
  padding: 12px;
}
.page-title { color: #F8FAFC; }
.help-icon {
  background-color: rgba(255,255,255,0.12);
  border-color: rgba(255,255,255,0.2);
}
.help-text { color: #F8FAFC; }
.info-tip {
  background-color: rgba(56,189,248,0.1);
  border: 1px solid rgba(56,189,248,0.3);
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}
.info-tip-text { color: #94A3B8; }
.section-title { color: #F8FAFC; }
.empty-text { color: #94A3B8; }
.empty-hint { color: #64748B; }
.empty-icon { color: #64748B; }
.loading-text { color: #94A3B8; }
