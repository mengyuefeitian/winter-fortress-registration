/* pages/user/position-list/position-list.wxss */

/* 页面容器 */
.page {
  min-height: 100vh;
  background-color: #fafbfc;
  padding: 12px;
}

/* 页面标题 */
.page-header {
  padding: 12px 4px;
  margin-bottom: 8px;
}

.page-title-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.page-title {
  font-size: 17px;
  font-weight: 600;
  color: #000000;
}

/* 帮助图标 */
.help-icon {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: #1296DB;
  display: flex;
  align-items: center;
  justify-content: center;
}

.help-text {
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

/* 提示信息 */
.info-tip {
  background-color: #F0F4FA;
  border-radius: 8px;
  padding: 12px;
  margin: 4px 0 12px 0;
}

.info-tip-text {
  font-size: 12px;
  color: #5F5F5F;
  line-height: 1.6;
}

/* 配置列表使用单列布局 */
.function-grid {
  display: flex;
  flex-direction: column;
  padding: 16px;
  gap: 12px;
}

/* 卡片样式覆盖 */
.card {
  width: 100%;
}

/* 分区信息条 */
.zone-info-bar {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  background: #fff;
  border-radius: 8px;
  margin-bottom: 12px;
  border: 1px solid #e5e7eb;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  justify-content: center;
  padding: 40px 16px;
}

.empty-state-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 8px;
}

.empty-text {
  color: #A6A6A6;
  font-size: 15px;
  font-weight: 500;
}

.empty-hint {
  color: #C0C0C0;
  font-size: 13px;
  text-align: center;
  line-height: 1.5;
}

/* ===== Dark Theme Override ===== */
.page { background: transparent !important; color: #F8FAFC; }
.page-header { padding: 12px 4px 8px; }
.page-title { color: #F8FAFC !important; }
.help-icon { background-color: rgba(255,255,255,0.12) !important; border: none; }
.help-text { color: #94A3B8 !important; }
.info-tip {
  background-color: rgba(56,189,248,0.08) !important;
  border: 1px solid rgba(56,189,248,0.25) !important;
  border-radius: 10px;
}
.info-tip-text { color: #94A3B8 !important; }
.zone-info-bar { color: #94A3B8; }
.card {
  background-color: rgba(255,255,255,0.07) !important;
  border: 1px solid rgba(255,255,255,0.13) !important;
}
.card-header { border-bottom-color: rgba(255,255,255,0.1) !important; }
.card-title { color: #F8FAFC !important; }
.tag { background-color: rgba(56,189,248,0.2) !important; color: #38BDF8 !important; }
.tag-primary { background-color: rgba(56,189,248,0.2) !important; color: #38BDF8 !important; }
.stats-row { color: #94A3B8; }
.text-secondary { color: #94A3B8 !important; }
.text-success { color: #10B981 !important; }
.text-danger { color: #EF4444 !important; }
.empty-state { color: #94A3B8; }
.empty-text { color: #94A3B8 !important; }
.empty-hint { color: #64748B !important; }
.loading-text { color: #94A3B8 !important; }
