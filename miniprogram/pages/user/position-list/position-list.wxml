<!-- pages/user/position-list/position-list.wxml -->
<view class="page">
  <!-- 页面标题 -->
  <view class="section-header">
    <text class="section-title">官职报名</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && configs.length === 0}}">
    <text class="empty-text">暂无可报名的官职</text>
  </view>

  <!-- 配置列表 -->
  <view class="function-grid" wx:if="{{!loading && configs.length > 0}}">
    <view class="card" wx:for="{{configs}}" wx:key="_id"
          bindtap="goToRegistration" data-config-id="{{item._id}}">
      <view class="card-header">
        <text class="card-title">{{item.positionType}}</text>
        <view class="tag tag-primary">{{item.date}}</view>
      </view>
      <view class="card-body">
        <text class="text-secondary">起始时间：{{item.startTime}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="safe-area-bottom p-16" wx:if="{{!loading}}">
    <button class="btn btn-secondary btn-full" bindtap="refreshData">刷新数据</button>
  </view>
</view>