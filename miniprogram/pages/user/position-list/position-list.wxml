<!--pages/user/position-list/position-list.wxml - Winter Fortress Redesign-->
<view class="container">
  <view class="nav-bar">
    <text class="nav-title">职位招募中心</text>
  </view>

  <view class="wf-card" wx:for="{{positionList}}" wx:key="id">
    <view class="flex-between">
      <view>
        <text class="position-name">{{item.name}}</text>
        <view class="mt-4 text-secondary text-xs">需求: {{item.required}}人 | 已报: {{item.current}}人</view>
      </view>
      <view class="wf-tag {{item.isFull ? 'full' : ''}}">{{item.isFull ? '已满员' : '报名中'}}</view>
    </view>
    <view class="mt-12" wx:if="{{!item.isFull}}">
      <button class="wf-btn" style="height: 36px; font-size: 13px;" bindtap="applyPosition" data-id="{{item.id}}">申请该职位</button>
    </view>
  </view>
</view>
