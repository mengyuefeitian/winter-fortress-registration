/* pages/user/registration/registration.wxss — Dark Theme */

.registration-container {
  min-height: 100vh;
  padding: 12px;
  color: #F8FAFC;
}

/* Page header */
.page-header { padding: 12px 4px; margin-bottom: 8px; }
.page-title-row { display: flex; align-items: center; gap: 8px; }
.page-title { font-size: 17px; font-weight: 600; color: #F8FAFC; }
.help-icon {
  width: 24px; height: 24px; border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center;
}
.help-text { font-size: 12px; color: #94A3B8; font-weight: 600; }

/* Info tip */
.info-tip {
  background-color: rgba(56,189,248,0.08);
  border: 1px solid rgba(56,189,248,0.25);
  border-radius: 10px; padding: 12px; margin-bottom: 12px;
}
.info-tip-text { font-size: 13px; color: #94A3B8; line-height: 1.6; }

/* Login tip */
.login-tip-section {
  background-color: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px; padding: 16px; text-align: center; margin-bottom: 12px;
}
.tip-text { color: #94A3B8; font-size: 14px; margin-bottom: 12px; }
.login-btn {
  background-color: #38BDF8; color: #0F172A; border: none;
  border-radius: 6px; padding: 8px 24px; font-size: 14px; font-weight: 600;
}

/* Card */
.card {
  background-color: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.13);
  border-radius: 12px; padding: 14px 16px; margin-bottom: 12px;
}

/* Zone info */
.zone-info-row { display: flex; align-items: center; margin-bottom: 10px; }
.zone-name-text { font-size: 15px; font-weight: 600; color: #F8FAFC; margin-left: 4px; }

/* Form */
.form-row { display: flex; gap: 12px; }
.form-col { flex: 1; }
.form-item { margin-bottom: 14px; }
.form-label { font-size: 13px; color: #94A3B8; margin-bottom: 6px; display: block; }
.form-input {
  width: 100%; height: 40px;
  background-color: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 8px; padding: 0 12px;
  font-size: 15px; color: #F8FAFC; box-sizing: border-box;
}

/* Picker */
.picker-compact {
  height: 38px;
  background-color: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 8px; padding: 0 12px;
  display: flex; align-items: center; justify-content: space-between;
  font-size: 14px; color: #F8FAFC;
}
.picker-compact.disabled { opacity: 0.35; }
.picker-placeholder { color: #64748B; }
.picker-compact-arrow { width: 14px; height: 14px; opacity: 0.4; }

/* Section header */
.section-header {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;
}
.section-title { font-size: 14px; font-weight: 600; color: #F8FAFC; }
.section-count { font-size: 12px; color: #64748B; }

/* Time slot list */
.time-slot-list { display: flex; flex-direction: column; gap: 8px; }
.time-slot-card {
  background-color: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px; padding: 12px 14px;
}
.time-slot-card:active { background-color: rgba(255,255,255,0.09); }
.time-slot-card.selected {
  border-color: #38BDF8;
  background-color: rgba(56,189,248,0.1);
}
.time-slot-card.my-slot {
  border-color: #10B981;
  background-color: rgba(16,185,129,0.08);
}
.time-slot-card.full { opacity: 0.45; }

.slot-header {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;
}
.slot-time { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; }
.time-value { font-size: 16px; font-weight: 600; color: #F8FAFC; }
.slot-tag {
  font-size: 11px; color: #94A3B8;
  background-color: rgba(255,255,255,0.08);
  border-radius: 4px; padding: 2px 7px;
}
.fortress-tag { background-color: rgba(56,189,248,0.15); color: #38BDF8; }
.corps-tag { background-color: rgba(251,191,36,0.15); color: #FBBF24; }
.activity-type-tag { background-color: rgba(167,139,250,0.15); color: #A78BFA; }
.my-badge {
  font-size: 11px; font-weight: 600; color: #10B981;
  background-color: rgba(16,185,129,0.15); border-radius: 4px; padding: 2px 8px;
}
.full-badge {
  font-size: 11px; font-weight: 600; color: #94A3B8;
  background-color: rgba(255,255,255,0.08); border-radius: 4px; padding: 2px 8px;
}
.slot-footer { display: flex; align-items: center; justify-content: space-between; }
.slot-date { font-size: 12px; color: #64748B; }
.slot-count { font-size: 12px; color: #94A3B8; }
.slot-count.full { color: #EF4444; }
.slot-counts { display: flex; gap: 12px; }

/* Position options */
.position-options { display: flex; gap: 10px; }
.position-option {
  flex: 1; border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8px; padding: 10px;
  display: flex; align-items: center; justify-content: center; gap: 6px;
  background-color: rgba(255,255,255,0.04);
}
.position-option.active {
  border-color: #38BDF8;
  background-color: rgba(56,189,248,0.12);
}
.position-icon { font-size: 16px; }
.position-name { font-size: 14px; color: #F8FAFC; }
.position-option.active .position-name { color: #38BDF8; font-weight: 600; }

/* Buttons */
.btn {
  height: 44px; line-height: 44px; border-radius: 8px;
  font-size: 15px; font-weight: 600; border: none; text-align: center;
}
.btn-primary { background-color: #38BDF8; color: #0F172A; }
.btn-primary:active { background-color: #0EA5E9; }
.btn-full { width: 100%; margin-top: 6px; }

/* Registration list */
.registration-list { display: flex; flex-direction: column; gap: 6px; }
.registration-item {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 10px;
  background-color: rgba(255,255,255,0.04); border-radius: 6px;
}
.registration-item.my-registration { background-color: rgba(56,189,248,0.08); }
.registration-order {
  width: 24px; height: 24px; border-radius: 50%;
  background-color: rgba(255,255,255,0.1);
  font-size: 12px; color: #94A3B8;
  display: flex; align-items: center; justify-content: center; font-weight: 600;
}
.my-order { background-color: #38BDF8; color: #0F172A; }
.registration-name {
  flex: 1; font-size: 14px; color: #F8FAFC;
  display: flex; align-items: center; gap: 4px;
}
.me-tag {
  font-size: 10px; color: #38BDF8;
  background-color: rgba(56,189,248,0.15);
  border-radius: 3px; padding: 1px 4px;
}
.registration-position { font-size: 12px; padding: 2px 8px; border-radius: 4px; }
.registration-position.head, .registration-position.combat {
  background-color: rgba(16,185,129,0.15); color: #10B981;
}
.registration-position.body, .registration-position.substitute {
  background-color: rgba(56,189,248,0.15); color: #38BDF8;
}

/* Share button */
.btn-share {
  background-color: transparent;
  border: 1px solid rgba(255,255,255,0.15);
  color: #94A3B8; border-radius: 8px; font-size: 14px;
}
.btn-share::after { border: none; }

/* Empty & loading */
.empty-state, .empty-state-content {
  padding: 30px; text-align: center;
  display: flex; flex-direction: column; align-items: center; gap: 8px;
}
.loading-container { padding: 30px; text-align: center; }
.empty-icon { font-size: 32px; }
.empty-text { font-size: 15px; color: #94A3B8; }
.empty-hint { font-size: 13px; color: #64748B; line-height: 1.5; }
.loading-text { font-size: 14px; color: #94A3B8; }

/* Utility */
.text-center { text-align: center; }
.text-secondary { color: #94A3B8; }
.text-sm { font-size: 13px; }
.mt-32 { margin-top: 32px; }
