@import "../registration/registration.wxss";

.position-option.active {
  background-color: #4A90D9;
  border-color: #4A90D9;
}

.position-option.active .position-name {
  color: #FFFFFF;
}

.position-position.combat {
  background-color: #FFE8E8;
  color: #FA5151;
}

.position-position.substitute {
  background-color: #F0FFF0;
  color: #07C160;
}

.activity-type-tag {
  background-color: #6BB3F0;
}

.slot-counts {
  display: flex;
  gap: 12px;
}

.slot-counts .slot-count {
  font-size: 13px;
  padding: 2px 8px;
  border-radius: 4px;
  background-color: #F5F5F5;
}

.slot-counts .slot-count.full {
  background-color: #FFE8E8;
  color: #FA5151;
}

/* ===== Dark Theme Overrides ===== */
.registration-container {
  min-height: 100vh;
  padding: 12px;
}
.page-title { color: #F8FAFC; }
.help-icon {
  background-color: rgba(255,255,255,0.12);
  border-color: rgba(255,255,255,0.2);
}
.help-text { color: #F8FAFC; }
.info-tip {
  background-color: rgba(56,189,248,0.1);
  border: 1px solid rgba(56,189,248,0.3);
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}
.info-tip-text { color: #94A3B8; }
.section-title { color: #F8FAFC; }
.empty-text { color: #94A3B8; }
.empty-hint { color: #64748B; }
.empty-icon { color: #64748B; }
.loading-text { color: #94A3B8; }
