/* pages/user/battle-registration/battle-registration.wxss — Dark Theme */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #0F172A;
  color: #F8FAFC;
}

.header {
  text-align: center;
  padding: 24rpx 0 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #F8FAFC;
  display: block;
}

.date {
  font-size: 28rpx;
  color: #38BDF8;
  margin-top: 8rpx;
  display: block;
}

.zone {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 4rpx;
  display: block;
}

.form {
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.13);
  border-radius: 16rpx;
  padding: 8rpx 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #94A3B8;
  width: 160rpx;
  flex-shrink: 0;
}

.input-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.input-group input {
  width: 100%;
  text-align: right;
  font-size: 28rpx;
  color: #F8FAFC;
}

.input-hint {
  font-size: 20rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.picker-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #F8FAFC;
}

.picker-select {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.picker-arrow {
  font-size: 22rpx;
  color: #38BDF8;
}

input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #F8FAFC;
}

.btn-submit {
  margin-top: 48rpx;
  background: linear-gradient(90deg, #38BDF8, #0EA5E9);
  color: #0F172A;
  border-radius: 16rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.mt-12 { margin-top: 12px; }
