/* pages/user/battle-registration/battle-registration.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #fafbfc;
}

.header {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  display: block;
}

.date {
  font-size: 28rpx;
  color: #4A90D9;
  margin-top: 8rpx;
  display: block;
}

.zone {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.form {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #333;
  width: 160rpx;
}

.input-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.input-group input {
  width: 100%;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.input-hint {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.picker-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #666;
}

.picker-select {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.picker-arrow {
  font-size: 22rpx;
  color: #4A90D9;
  margin-left: 4rpx;
}

input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.btn-submit {
  margin-top: 60rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}
