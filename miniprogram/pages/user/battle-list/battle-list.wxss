/* pages/user/battle-list/battle-list.wxss */
.nav-bar {
  padding: 16px 0;
}

.help-icon {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--wf-glass);
  border: 1px solid var(--wf-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: var(--wf-primary);
}

.empty-state {
  margin-top: 80px;
  text-align: center;
  color: var(--wf-text-sub);
}

.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 16px;
  opacity: 0.8;
}

.empty-text {
  font-size: 16px;
  font-weight: 600;
  display: block;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 13px;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  background: rgba(15, 23, 42, 0.98);
  border-top: 1px solid var(--wf-border);
  display: flex;
  gap: 12px;
}
