<!--pages/user/battle-list/battle-list.wxml - Winter Fortress Redesign-->
<view class="container">
  <view class="nav-bar flex-between">
    <text class="nav-title">⚔️ 国战报名</text>
    <view class="help-icon" bindtap="toggleTip">?</view>
  </view>

  <!-- 提示信息 -->
  <view wx:if="{{showTip}}" class="wf-card mt-12" style="border-color: var(--wf-primary);">
    <text class="text-xs text-secondary">分区管理员可在此创建国战，用户点击日期即可报名。区管可在统计表中分配车身。</text>
  </view>

  <!-- 创建区 (管理员) -->
  <view class="wf-card mt-12" wx:if="{{canCreate}}">
    <view class="flex-between">
      <text class="text-sm">选择国战日期</text>
      <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange">
        <view class="wf-tag">{{selectedDate}}</view>
      </picker>
    </view>
    <button class="wf-btn mt-12" style="height: 36px; font-size: 13px;" bindtap="onCreateConfig">创建国战任务</button>
  </view>

  <!-- 列表 -->
  <view class="mt-24" wx:if="{{configs.length > 0}}">
    <view class="wf-card" wx:for="{{configs}}" wx:key="_id" bindtap="onConfigSelect" data-id="{{item._id}}">
      <view class="flex-between">
        <view>
          <text class="position-name">{{item.date}}</text>
          <view class="mt-4 text-secondary text-xs" wx:if="{{item.zoneName}}">分区: {{item.zoneName}}</view>
        </view>
        <view style="display: flex; align-items: center; gap: 8px;">
          <view class="wf-tag">待报名</view>
          <view wx:if="{{isSuperAdmin}}" class="wf-tag" style="background: #FF6B6B; color: #fff;" catchtap="onDeleteConfig" data-id="{{item._id}}" data-date="{{item.date}}">删除</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">🛡️</text>
    <text class="empty-text">暂无国战任务</text>
    <text class="empty-hint">等待指挥官发布新的作战计划</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar" wx:if="{{configs.length > 0}}">
    <button class="wf-btn" bindtap="onStatistics" style="flex: 1; margin-right: 8px;">查看统计</button>
    <button class="wf-btn" bindtap="onAllocation" style="flex: 1; background: transparent; border: 1px solid var(--wf-border); box-shadow: none;">分配表</button>
  </view>
</view>
