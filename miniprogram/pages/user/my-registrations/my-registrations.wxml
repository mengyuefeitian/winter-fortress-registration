<!-- pages/user/my-registrations/my-registrations.wxml -->
<view class="page">
  <!-- 用户信息 -->
  <view class="card mt-16 user-card">
    <view class="card-body flex items-center">
      <image class="avatar-lg" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="ml-16 flex-1">
        <text class="text-lg font-semibold">{{userInfo.nickName || '未登录'}}</text>
        <view class="flex items-center mt-8">
          <view class="status-dot {{isLoggedIn ? 'status-active' : 'status-inactive'}}"></view>
          <text class="text-secondary">{{roleName}}</text>
        </view>
      </view>
      <!-- 分区选择器 + 信封入口（上下排列） -->
      <view wx:if="{{isLoggedIn}}" class="side-actions">
        <zone-selector value="{{currentZone}}" zones="{{zones}}" loaded="{{zonesLoaded}}" bind:change="onZoneChange" />
        <view class="letter-btn" bindtap="goToInbox">
          <image class="letter-icon" src="/images/icon-letter.svg" mode="aspectFit" />
        </view>
      </view>
    </view>
    <view class="card-footer">
      <button wx:if="{{isLoggedIn}}" class="btn btn-danger btn-logout" bindtap="logout">退出登录</button>
      <button wx:else class="btn btn-primary btn-full" bindtap="goToLogin">登录</button>
    </view>
  </view>

  <!-- 当前分区信息 -->
  <view wx:if="{{isLoggedIn && currentZone}}" class="zone-info-bar">
    <text class="zone-info-text">当前分区：{{currentZone.zoneName}}（{{currentZone.zoneCode}}）</text>
  </view>

  <!-- 堡垒报名记录 -->
  <view class="section-header">
    <text class="section-title">堡垒报名记录</text>
  </view>

  <view wx:if="{{registrations.length === 0}}" class="empty-compact">
    <text class="empty-compact-text">暂无报名记录</text>
    <view class="empty-compact-btn" bindtap="goToRegistration">去报名</view>
  </view>

  <view wx:else class="table-container">
    <!-- 移除状态列 -->
    <view class="table-row table-header-row">
      <text class="table-cell time-header">时间/标签</text>
      <text class="table-cell">昵称</text>
      <text class="table-cell">联盟</text>
      <text class="table-cell action-cell">操作</text>
    </view>
    <view wx:for="{{registrations}}" wx:key="_id" class="table-row">
      <!-- 时间标签三行展示 -->
      <view class="table-cell time-cell">
        <text wx:if="{{item.formattedDate}}" class="time-date-small">{{item.formattedDate}}</text>
        <text class="time-main">{{item.displayName}}</text>
        <text wx:if="{{item.timeFortress}}" class="time-tag-inline fortress-tag">{{item.timeFortress}}</text>
        <text wx:if="{{item.timeTag}}" class="time-tag-inline">{{item.timeTag}}</text>
      </view>
      <text class="table-cell">{{item.nickName}}</text>
      <text class="table-cell">
        <text>{{item.shortAllianceName}}</text>
        <text wx:if="{{item.zoneCode}}" class="zone-tag">[{{item.zoneCode}}区]</text>
      </text>
      <view class="table-cell action-cell">
        <view class="cancel-btn-small" bindtap="cancelRegistration" data-id="{{item._id}}" data-index="{{index}}">取消</view>
      </view>
    </view>
  </view>

  <!-- 官职报名记录 -->
  <view class="section-header mt-24">
    <text class="section-title">官职报名记录</text>
  </view>

  <view wx:if="{{positionRegistrations.length === 0}}" class="empty-compact">
    <text class="empty-compact-text">暂无官职报名记录</text>
    <view class="empty-compact-btn" bindtap="goToPositionList">去报名</view>
  </view>

  <view wx:else class="table-container">
    <!-- 移除状态列 -->
    <view class="table-row table-header-row">
      <text class="table-cell time-header">时间/日期</text>
      <text class="table-cell">昵称</text>
      <text class="table-cell">职位</text>
      <text class="table-cell action-cell">操作</text>
    </view>
    <view wx:for="{{positionRegistrations}}" wx:key="_id" class="table-row">
      <!-- 时间两行展示 -->
      <view class="table-cell time-cell">
        <text class="time-main">{{item.timeSlot}}</text>
        <text wx:if="{{item.configInfo.date}}" class="time-date-small">{{item.configInfo.date}}</text>
      </view>
      <text class="table-cell">{{item.nickName}}</text>
      <text class="table-cell">{{item.configInfo.positionType}}</text>
      <view class="table-cell action-cell">
        <view class="cancel-btn-small" bindtap="cancelPositionRegistration" data-id="{{item._id}}" data-index="{{index}}">取消</view>
      </view>
    </view>
  </view>

  <!-- 兵工厂报名 -->
  <view class="section-header mt-24">
    <text class="section-title">兵工厂报名</text>
  </view>

  <view wx:if="{{arsenalRegistrations.length === 0}}" class="empty-compact">
    <text class="empty-compact-text">暂无兵工厂报名记录</text>
    <view class="empty-compact-btn" bindtap="goToArsenal">去报名</view>
  </view>

  <view wx:else class="table-container">
    <view class="table-row table-header-row">
      <text class="table-cell time-header">时间/日期</text>
      <text class="table-cell">昵称</text>
      <text class="table-cell">军团</text>
      <text class="table-cell action-cell">操作</text>
    </view>
    <view wx:for="{{arsenalRegistrations}}" wx:key="_id" class="table-row">
      <view class="table-cell time-cell">
        <text class="time-main">{{item.time}}</text>
        <text wx:if="{{item.date}}" class="time-date-small">{{item.date}}</text>
      </view>
      <text class="table-cell">{{item.nickName}}</text>
      <text class="table-cell">{{item.corps}}</text>
      <view class="table-cell action-cell">
        <view class="cancel-btn-small" bindtap="cancelArsenalRegistration" data-id="{{item._id}}" data-index="{{index}}">取消</view>
      </view>
    </view>
  </view>

  <!-- 峡谷会战报名 -->
  <view class="section-header mt-24">
    <text class="section-title">峡谷会战报名</text>
  </view>

  <view wx:if="{{canyonRegistrations.length === 0}}" class="empty-compact">
    <text class="empty-compact-text">暂无峡谷会战报名记录</text>
    <view class="empty-compact-btn" bindtap="goToCanyon">去报名</view>
  </view>

  <view wx:else class="table-container">
    <view class="table-row table-header-row">
      <text class="table-cell time-header">时间/日期</text>
      <text class="table-cell">昵称</text>
      <text class="table-cell">军团</text>
      <text class="table-cell action-cell">操作</text>
    </view>
    <view wx:for="{{canyonRegistrations}}" wx:key="_id" class="table-row">
      <view class="table-cell time-cell">
        <text class="time-main">{{item.time}}</text>
        <text wx:if="{{item.date}}" class="time-date-small">{{item.date}}</text>
      </view>
      <text class="table-cell">{{item.nickName}}</text>
      <text class="table-cell">{{item.corps}}</text>
      <view class="table-cell action-cell">
        <view class="cancel-btn-small" bindtap="cancelCanyonRegistration" data-id="{{item._id}}" data-index="{{index}}">取消</view>
      </view>
    </view>
  </view>

  <!-- 意见反馈 -->
  <view class="section-header mt-24">
    <text class="section-title">帮助与反馈</text>
  </view>

  <view class="card">
    <view class="feedback-entry" bindtap="goToFeedback">
      <view class="feedback-icon">💬</view>
      <view class="feedback-content">
        <text class="feedback-name">意见与建议</text>
        <text class="feedback-desc">反馈需求或问题</text>
      </view>
      <text class="feedback-arrow">›</text>
    </view>
  </view>

  <!-- 底部版本号 -->
  <view class="text-center mt-32 mb-16">
    <text class="text-weak text-xs">{{versionText}}</text>
  </view>
</view>
