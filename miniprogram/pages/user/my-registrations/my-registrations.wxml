<view class="page">
  <!-- 用户信息 -->
  <view class="card mt-16">
    <view class="card-body flex items-center">
      <image class="avatar-lg" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="ml-16 flex-1">
        <text class="text-lg font-semibold">{{userInfo.nickName || '未登录'}}</text>
        <view class="flex items-center mt-8">
          <view class="status-dot {{isLoggedIn ? 'status-active' : 'status-inactive'}}"></view>
          <text class="text-secondary">{{roleName}}</text>
        </view>
      </view>
    </view>
    <view class="card-footer">
      <button wx:if="{{isLoggedIn}}" class="btn btn-danger btn-full" bindtap="logout">退出登录</button>
      <button wx:else class="btn btn-primary btn-full" bindtap="goToLogin">登录</button>
    </view>
  </view>

  <!-- 堡垒报名记录 -->
  <view class="section-header">
    <text class="section-title">堡垒报名记录</text>
  </view>

  <view wx:if="{{registrations.length === 0}}" class="card">
    <view class="empty-state">
      <text class="empty-text">暂无报名记录</text>
      <view class="empty-action">
        <button class="btn btn-primary" bindtap="goToRegistration">去报名</button>
      </view>
    </view>
  </view>

  <view wx:else class="table">
    <view class="table-header">
      <view class="table-cell table-cell-header" style="width: 80px;">时间</view>
      <view class="table-cell table-cell-header">联盟</view>
      <view class="table-cell table-cell-header" style="width: 60px;">状态</view>
      <view class="table-cell table-cell-header" style="width: 80px;">操作</view>
    </view>
    <view wx:for="{{registrations}}" wx:key="_id" class="table-row">
      <view class="table-cell table-cell-time" style="width: 80px;">{{item.displayName}}</view>
      <view class="table-cell table-cell-name">{{item.allianceName}}</view>
      <view class="table-cell" style="width: 60px;">
        <text class="tag tag-success">有效</text>
      </view>
      <view class="table-cell" style="width: 80px;">
        <button class="btn btn-sm btn-ghost" bindtap="cancelRegistration" data-id="{{item._id}}" data-index="{{index}}">取消</button>
      </view>
    </view>
  </view>

  <!-- 官职报名记录 -->
  <view class="section-header mt-24">
    <text class="section-title">官职报名记录</text>
  </view>

  <view wx:if="{{positionRegistrations.length === 0}}" class="card">
    <view class="empty-state">
      <text class="empty-text">暂无官职报名记录</text>
    </view>
  </view>

  <view wx:else class="table">
    <view class="table-header">
      <view class="table-cell table-cell-header" style="width: 80px;">时间</view>
      <view class="table-cell table-cell-header">官职类型</view>
      <view class="table-cell table-cell-header" style="width: 60px;">状态</view>
      <view class="table-cell table-cell-header" style="width: 80px;">操作</view>
    </view>
    <view wx:for="{{positionRegistrations}}" wx:key="_id" class="table-row">
      <view class="table-cell table-cell-time" style="width: 80px;">{{item.timeSlot}}</view>
      <view class="table-cell table-cell-name">{{item.configInfo.positionType}}</view>
      <view class="table-cell" style="width: 60px;">
        <text class="tag tag-success">有效</text>
      </view>
      <view class="table-cell" style="width: 80px;">
        <button class="btn btn-sm btn-ghost" bindtap="cancelPositionRegistration" data-id="{{item._id}}" data-index="{{index}}">取消</button>
      </view>
    </view>
  </view>
</view>