/* pages/user/my-registrations/my-registrations.wxss — Dark Theme */

.page {
  min-height: 100vh;
  padding-bottom: 20px;
}

.card {
  background-color: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.13);
  border-radius: 12px;
  margin: 12px 16px;
  padding: 14px 16px;
}

.card-body { display: flex; align-items: center; }

.avatar-lg {
  width: 48px; height: 48px; border-radius: 24px;
  border: 2px solid rgba(255,255,255,0.2);
}

.ml-16 { margin-left: 16px; }
.flex-1 { flex: 1; }
.text-lg { font-size: 17px; color: #F8FAFC; }
.font-semibold { font-weight: 600; }
.text-secondary { color: #94A3B8; }
.mt-8 { margin-top: 8px; }
.mt-16 { margin-top: 16px; }
.mt-24 { margin-top: 24px; }
.flex { display: flex; }
.items-center { align-items: center; }

.status-dot {
  width: 8px; height: 8px; border-radius: 4px; margin-right: 6px;
}
.status-active { background-color: #10B981; }
.status-inactive { background-color: #64748B; }

.card-footer {
  margin-top: 14px; padding-top: 14px;
  border-top: 1px solid rgba(255,255,255,0.1);
}

.btn { height: 44px; line-height: 44px; font-size: 15px; border-radius: 8px; border: none; }
.btn-full { width: 100%; }
.btn-primary { background-color: #38BDF8; color: #0F172A; font-weight: 600; }
.btn-danger { background-color: #EF4444; color: #fff; font-weight: 600; }

.section-header { margin: 14px 16px 6px; }
.section-title { font-size: 13px; font-weight: 600; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.5px; }

.empty-state { padding: 24px; text-align: center; }
.empty-text { color: #64748B; font-size: 15px; display: block; }
.empty-action { margin-top: 16px; }
.empty-action .btn { width: auto; padding: 0 24px; }

/* 表格 */
.table-container {
  background-color: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.13);
  margin: 0 16px;
  border-radius: 10px;
  overflow: hidden;
}

.table-row {
  display: flex; align-items: center;
  padding: 11px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.table-row:last-child { border-bottom: none; }

.table-header-row {
  background-color: rgba(255,255,255,0.05);
  padding: 9px 14px;
}

.table-cell {
  flex: 1; font-size: 14px; color: #F8FAFC;
  text-align: left; min-width: 0;
}
.table-header-row .table-cell {
  font-size: 12px; color: #94A3B8; font-weight: 600;
}

.time-cell {
  flex: 1.5; display: flex; flex-direction: column;
  align-items: flex-start; gap: 2px; min-height: 44px;
}
.time-header { flex: 1.5; }
.time-main { font-size: 14px; font-weight: 500; color: #F8FAFC; line-height: 1.4; }
.time-tag-inline {
  display: inline-block;
  background-color: rgba(56,189,248,0.2); color: #38BDF8;
  font-size: 11px; padding: 2px 6px; border-radius: 4px;
}
.time-date-small { font-size: 12px; color: #64748B; line-height: 1.3; }

.action-cell { flex: 0 0 50px; text-align: center; }

.cancel-btn-small {
  display: inline-block; font-size: 12px; color: #EF4444;
  padding: 4px 8px; border-radius: 4px;
  background-color: rgba(239,68,68,0.12);
}
.cancel-btn-small:active { background-color: rgba(239,68,68,0.2); }

.zone-info-bar {
  margin: 0 16px; padding: 8px 14px;
  background-color: rgba(56,189,248,0.08);
  border-radius: 6px; border: 1px solid rgba(56,189,248,0.2);
}
.zone-info-text { font-size: 13px; color: #38BDF8; }

.zone-code-cell { font-size: 13px; color: #64748B; font-weight: 500; }

.feedback-entry { display: flex; align-items: center; padding: 12px 0; }
.feedback-icon {
  font-size: 22px; margin-right: 12px;
  display: flex; align-items: center; justify-content: center;
  width: 36px; height: 36px;
  background: rgba(56,189,248,0.1); border-radius: 8px;
}
.feedback-content { flex: 1; }
.feedback-name { font-size: 15px; font-weight: 500; color: #F8FAFC; display: block; }
.feedback-desc { font-size: 13px; color: #64748B; margin-top: 2px; display: block; }
.feedback-arrow { font-size: 20px; color: #94A3B8; margin-left: 8px; }

.text-center { text-align: center; }
.text-weak { color: #64748B; }
.text-xs { font-size: 12px; }
.text-sm { font-size: 13px; }
.mb-16 { margin-bottom: 16px; }
.mt-32 { margin-top: 32px; }
.mt-4 { margin-top: 4px; }
.text-weak { color: #64748B; }
