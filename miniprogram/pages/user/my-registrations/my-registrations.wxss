/* pages/user/my-registrations/my-registrations.wxss */

.my-registrations-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

/* 用户信息区域 */
.user-info-section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.user-card {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.user-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background-color: #E8E8E8;
  margin-right: 16px;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 18px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4px;
}

.user-role {
  font-size: 14px;
  color: #4A90D9;
  margin-bottom: 4px;
}

.user-phone {
  font-size: 12px;
  color: #999999;
}

.user-actions {
  margin-top: 12px;
}

.logout-btn {
  background-color: #FF6B6B;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 10px 20px;
  font-size: 14px;
}

.login-btn {
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 10px 20px;
  font-size: 14px;
  margin-top: 12px;
}

/* 本周报名区域 */
.weekly-section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12px;
}

.weekly-empty {
  text-align: center;
  padding: 20px;
}

.empty-text {
  font-size: 14px;
  color: #999999;
  margin-bottom: 12px;
}

.empty-btn {
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 10px 24px;
  font-size: 14px;
}

.weekly-list {
  display: flex;
  flex-direction: column;
}

.weekly-card {
  background-color: #E8F4FF;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 8px;
}

.weekly-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.weekly-zone {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
}

.weekly-alliance {
  font-size: 13px;
  color: #4A90D9;
}

.weekly-body {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.weekly-time,
.weekly-remark,
.weekly-position {
  display: flex;
  align-items: center;
}

.time-label,
.remark-label,
.position-label {
  font-size: 12px;
  color: #666666;
  margin-right: 4px;
}

.time-value {
  font-size: 13px;
  color: #333333;
  font-weight: 500;
}

.remark-value {
  font-size: 12px;
  color: #666666;
}

.position-value {
  font-size: 12px;
  padding: 2px 6px;
  border-radius: 4px;
}

.position-value.head {
  background-color: #FFE8E8;
  color: #FF6B6B;
}

.position-value.body {
  background-color: #E8FFE8;
  color: #52C41A;
}

/* 全部报名区域 */
.all-section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.empty-state {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40px 20px;
}

.empty-icon {
  width: 80px;
  height: 80px;
  margin-bottom: 16px;
}

.registration-list {
  display: flex;
  flex-direction: column;
}

.registration-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 8px;
  border-bottom: 1px solid #E8E8E8;
}

.card-zone {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
}

.card-alliance {
  font-size: 13px;
  color: #4A90D9;
}

.card-body {
  padding: 8px 0;
}

.info-row {
  display: flex;
  margin-bottom: 6px;
}

.info-label {
  font-size: 13px;
  color: #666666;
  width: 70px;
}

.info-value {
  font-size: 13px;
  color: #333333;
}

.remark-text {
  color: #666666;
}

.position-tag {
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
}

.position-tag.head {
  background-color: #FFE8E8;
  color: #FF6B6B;
}

.position-tag.body {
  background-color: #E8FFE8;
  color: #52C41A;
}

.card-footer {
  padding-top: 8px;
  border-top: 1px solid #E8E8E8;
}

.cancel-btn {
  background-color: transparent;
  color: #FF6B6B;
  border: 1px solid #FF6B6B;
  border-radius: 6px;
  padding: 8px 16px;
  font-size: 13px;
  width: 100%;
}

.cancel-btn:active {
  background-color: #FFE8E8;
}

/* 官职报名区域 */
.position-section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-top: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.position-card .card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-position-type {
  font-size: 14px;
  font-weight: 500;
  color: #1a1a2e;
}

.card-date {
  font-size: 13px;
  color: #e94560;
  padding: 2px 8px;
  background-color: #fef2f2;
  border-radius: 4px;
}