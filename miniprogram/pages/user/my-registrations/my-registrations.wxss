/* pages/user/my-registrations/my-registrations.wxss */

.my-registrations-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.empty-state {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80px 20px;
}

.empty-icon {
  width: 100px;
  height: 100px;
  margin-bottom: 20px;
}

.empty-text {
  font-size: 14px;
  color: #999999;
  margin-bottom: 20px;
}

.empty-btn {
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
}

.registration-list {
  display: flex;
  flex-direction: column;
}

.registration-card {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 12px;
  border-bottom: 1px solid #E8E8E8;
}

.card-zone {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.card-alliance {
  font-size: 14px;
  color: #4A90D9;
}

.card-body {
  padding: 12px 0;
}

.info-row {
  display: flex;
  margin-bottom: 8px;
}

.info-label {
  font-size: 14px;
  color: #666666;
  width: 80px;
}

.info-value {
  font-size: 14px;
  color: #333333;
}

.position-tag {
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
}

.position-tag.head {
  background-color: #FFE8E8;
  color: #FF6B6B;
}

.position-tag.body {
  background-color: #E8FFE8;
  color: #52C41A;
}

.card-footer {
  padding-top: 12px;
  border-top: 1px solid #E8E8E8;
}

.cancel-btn {
  background-color: transparent;
  color: #FF6B6B;
  border: 1px solid #FF6B6B;
  border-radius: 8px;
  padding: 10px 20px;
  font-size: 14px;
  width: 100%;
}

.cancel-btn:active {
  background-color: #FFE8E8;
}