/* pages/user/registration/registration.wxss */

.registration-container {
  padding: 16px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.section {
  background-color: #FFFFFF;
  border-radius: 10px;
  padding: 12px;
  margin-bottom: 12px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 10px;
}

/* 选择器样式 */
.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F5F7FA;
  border-radius: 6px;
  padding: 10px 12px;
  font-size: 14px;
}

.picker-arrow {
  width: 14px;
  height: 14px;
}

.empty-picker {
  background-color: #F5F7FA;
  border-radius: 6px;
  padding: 10px 12px;
  text-align: center;
  color: #999999;
  font-size: 13px;
}

.empty-tip {
  text-align: center;
  padding: 16px;
  color: #999999;
  font-size: 13px;
}

/* 登录提示 */
.login-tip-section {
  background-color: #FFF3E0;
  border-radius: 10px;
  padding: 20px;
  margin-bottom: 12px;
  text-align: center;
}

.tip-text {
  font-size: 14px;
  color: #E65100;
  margin-bottom: 12px;
}

.login-tip-section .login-btn {
  background-color: #FF9800;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 10px 24px;
  font-size: 14px;
}

/* 时间段卡片 - 每行2个 */
.time-slot-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.time-slot-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 10px;
  border: 2px solid transparent;
  transition: all 0.2s ease;
  position: relative;
  text-align: center;
}

.time-slot-card:active {
  background-color: #E8F4FF;
}

.time-slot-card.full {
  background-color: #F5F5F5;
  opacity: 0.6;
}

.time-slot-card.selected {
  border-color: #4A90D9;
  background-color: #E8F4FF;
}

.slot-time {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4px;
}

.slot-count {
  font-size: 12px;
  color: #666666;
}

.slot-count.full {
  color: #FF6B6B;
}

.slot-remark {
  font-size: 10px;
  color: #999999;
  margin-top: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.full-badge {
  position: absolute;
  top: 4px;
  right: 4px;
  background-color: #FF6B6B;
  color: #FFFFFF;
  font-size: 10px;
  padding: 1px 4px;
  border-radius: 4px;
}

/* 表单样式 */
.form-section {
  padding: 12px;
}

.form-item {
  margin-bottom: 12px;
}

.form-label {
  font-size: 13px;
  color: #666666;
  margin-bottom: 6px;
}

.form-input {
  width: 100%;
  height: 36px;
  background-color: #F5F7FA;
  border-radius: 6px;
  padding: 0 10px;
  font-size: 14px;
}

/* 位置选择 */
.position-options {
  display: flex;
  justify-content: space-around;
  gap: 10px;
}

.position-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px;
  background-color: #F5F7FA;
  border-radius: 8px;
  transition: all 0.2s ease;
  border: 2px solid transparent;
}

.position-option.active {
  background-color: #4A90D9;
  border-color: #4A90D9;
}

.position-icon {
  font-size: 20px;
  margin-bottom: 4px;
}

.position-name {
  font-size: 13px;
  color: #666666;
}

.position-option.active .position-name {
  color: #FFFFFF;
}

.submit-btn {
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 10px 24px;
  font-size: 15px;
  width: 100%;
  margin-top: 16px;
}

.submit-btn:active {
  background-color: #3A80C9;
}

/* 已报名人员预览 */
.preview-section {
  margin-bottom: 0;
}

.registration-list {
  display: flex;
  flex-direction: column;
}

.registration-item {
  display: flex;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #E8E8E8;
}

.registration-item:last-child {
  border-bottom: none;
}

.registration-order {
  width: 20px;
  height: 20px;
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 11px;
  text-align: center;
  line-height: 20px;
  margin-right: 10px;
}

.registration-name {
  flex: 1;
  font-size: 13px;
  color: #333333;
}

.registration-position {
  font-size: 11px;
  padding: 2px 6px;
  border-radius: 4px;
}

.registration-position.head {
  background-color: #FFE8E8;
  color: #FF6B6B;
}

.registration-position.body {
  background-color: #E8FFE8;
  color: #52C41A;
}