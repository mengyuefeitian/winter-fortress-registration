/* pages/user/registration/registration.wxss */

.registration-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12px;
}

/* 选择器样式 */
.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 12px 16px;
}

.picker-arrow {
  width: 16px;
  height: 16px;
}

/* 时间段卡片 */
.time-slot-list {
  display: flex;
  flex-direction: column;
}

.time-slot-card {
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
  border: 1px solid #E8E8E8;
  transition: all 0.3s ease;
}

.time-slot-card:active {
  background-color: #F0F7FF;
}

.time-slot-card.full {
  background-color: #F5F5F5;
  opacity: 0.6;
  pointer-events: none;
}

.time-slot-card.selected {
  border-color: #4A90D9;
  background-color: #F0F7FF;
}

.time-slot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time-slot-time {
  font-size: 18px;
  font-weight: 500;
  color: #333333;
}

.time-slot-count {
  font-size: 14px;
  color: #666666;
}

.time-slot-count.full {
  color: #FF6B6B;
}

.time-slot-remark {
  font-size: 12px;
  color: #999999;
  margin-top: 8px;
}

.time-slot-progress {
  margin-top: 12px;
}

.progress-bar {
  height: 6px;
  background-color: #E8E8E8;
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #4A90D9;
  border-radius: 3px;
  transition: width 0.3s ease;
}

.progress-fill.full {
  background-color: #FF6B6B;
}

.full-badge {
  position: absolute;
  top: 8px;
  right: 8px;
  background-color: #FF6B6B;
  color: #FFFFFF;
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 4px;
}

.time-slot-card {
  position: relative;
}

/* 表单样式 */
.form-section {
  padding: 20px 16px;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #666666;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 40px;
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
}

/* 位置选择 */
.position-options {
  display: flex;
  justify-content: space-around;
}

.position-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px;
  background-color: #F5F7FA;
  border-radius: 8px;
  margin: 0 8px;
  transition: all 0.3s ease;
}

.position-option.active {
  background-color: #4A90D9;
}

.position-icon {
  font-size: 24px;
  margin-bottom: 8px;
}

.position-name {
  font-size: 14px;
  color: #666666;
}

.position-option.active .position-name {
  color: #FFFFFF;
}

.submit-btn {
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
  width: 100%;
  margin-top: 24px;
}

.submit-btn:active {
  background-color: #3A80C9;
}

/* 已报名人员预览 */
.preview-section {
  margin-bottom: 0;
}

.registration-list {
  display: flex;
  flex-direction: column;
}

.registration-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #E8E8E8;
}

.registration-item:last-child {
  border-bottom: none;
}

.registration-order {
  width: 24px;
  height: 24px;
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 12px;
  text-align: center;
  line-height: 24px;
  margin-right: 12px;
}

.registration-name {
  flex: 1;
  font-size: 14px;
  color: #333333;
}

.registration-position {
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
}

.registration-position.head {
  background-color: #FFE8E8;
  color: #FF6B6B;
}

.registration-position.body {
  background-color: #E8FFE8;
  color: #52C41A;
}