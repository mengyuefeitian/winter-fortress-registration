<!--pages/index/index.wxml - Winter Fortress Redesign-->
<view class="page">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="container flex-center" style="min-height: 100vh; flex-direction: column;">
    <view class="login-header" style="margin-bottom: 40px;">
      <view class="title">❄️ 冬日堡垒</view>
      <view class="desc">联盟活动报名系统</view>
    </view>
    <button class="wf-btn" bindtap="handleLogin" style="width: 200px;">指挥官登录</button>
  </view>

  <!-- 已登录状态 -->
  <view wx:if="{{isLoggedIn}}" class="container">
    
    <!-- 用户信息卡片 -->
    <view class="wf-card flex-between" style="margin-top: 20px;">
      <view class="flex-center" style="gap: 12px;">
        <image class="avatar-lg" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" style="width: 48px; height: 48px; border-radius: 50%; border: 2px solid var(--wf-border);" />
        <view>
          <text class="text-lg font-semibold">{{userInfo.nickName || '指挥官'}}</text>
          <view class="flex-center mt-4" style="gap: 4px;">
            <view class="status-dot status-active"></view>
            <text class="text-secondary text-xs">{{roleDisplayName}}</text>
          </view>
        </view>
      </view>
      <zone-selector value="{{currentZone}}" zones="{{zones}}" loaded="{{zonesLoaded}}" bind:change="onZoneChange" />
    </view>

    <!-- 分区引导 -->
    <view wx:if="{{zonesLoaded && zones.length > 0 && !currentZone}}" class="wf-card" style="border-color: var(--wf-primary);">
      <text class="text-sm">请选择您的分区，以便查看对应联盟和报名信息</text>
      <view class="wf-btn mt-12" style="height: 36px; font-size: 13px;" bindtap="applyCreateZone">申请开通分区</view>
    </view>

    <!-- 功能网格 -->
    <view class="section-header mt-24">
      <text class="section-title">指挥中心</text>
    </view>

    <view class="function-grid">
      <!-- 堡垒报名 -->
      <view class="grid-item" bindtap="goToFortressRegistration" wx:if="{{showFortressRegistration}}">
        <view class="grid-icon">🏰</view>
        <text class="grid-name">堡垒报名</text>
      </view>

      <!-- 官职报名 -->
      <view class="grid-item" bindtap="goToPositionRegistration" wx:if="{{showPositionRegistration}}">
        <view class="grid-icon">👑</view>
        <text class="grid-name">官职报名</text>
      </view>

      <!-- 国战报名 -->
      <view class="grid-item" bindtap="goToBattleRegistration" wx:if="{{showBattleRegistration}}">
        <view class="grid-icon">⚔️</view>
        <text class="grid-name">国战报名</text>
      </view>

      <!-- 兵工厂报名 -->
      <view class="grid-item" bindtap="goToArsenalRegistration" wx:if="{{showBattleRegistration}}">
        <view class="grid-icon">🔫</view>
        <text class="grid-name">兵工厂</text>
      </view>

      <!-- 峡谷会战报名 -->
      <view class="grid-item" bindtap="goToCanyonRegistration" wx:if="{{showBattleRegistration}}">
        <view class="grid-icon">🏔️</view>
        <text class="grid-name">峡谷会战</text>
      </view>

      <!-- 我的报名 -->
      <view class="grid-item" bindtap="goToMyRegistrations" wx:if="{{showMyRegistrations}}">
        <view class="grid-icon">📝</view>
        <text class="grid-name">我的报名</text>
      </view>

      <!-- 申请盟管 -->
      <view class="grid-item" bindtap="applyAllianceManager" wx:if="{{showApplyAllianceManager}}">
        <view class="grid-icon">🛡️</view>
        <text class="grid-name">申请盟管</text>
      </view>

      <!-- 申请区管 -->
      <view class="grid-item" bindtap="applyZoneManager" wx:if="{{showApplyZoneManager}}">
        <view class="grid-icon">🏅</view>
        <text class="grid-name">申请区管</text>
      </view>

      <!-- 盟管控制台 -->
      <view class="grid-item" bindtap="goToAuditorConsole" wx:if="{{showAuditorConsole}}">
        <image class="grid-icon-img" src="/images/icon-home-alliance.svg" mode="aspectFit" />
        <text class="grid-name">盟管后台</text>
      </view>

      <!-- 超管控制台 -->
      <view class="grid-item" bindtap="goToSuperAdminConsole" wx:if="{{showSuperAdminConsole}}">
        <image class="grid-icon-img" src="/images/icon-home-superadmin.svg" mode="aspectFit" />
        <text class="grid-name">超管后台</text>
      </view>

      <!-- 区管控制台 -->
      <view class="grid-item" bindtap="goToAdminConsole" wx:if="{{showAdminConsole}}">
        <image class="grid-icon-img" src="/images/icon-home-zone.svg" mode="aspectFit" />
        <text class="grid-name">区管后台</text>
        <view wx:if="{{pendingAdminReviewCount > 0}}" class="badge">{{pendingAdminReviewCount}}</view>
      </view>
    </view>

    <!-- 分享按钮 -->
    <view class="mt-32">
      <button class="wf-btn" open-type="share" style="background: transparent; border: 1px solid var(--wf-border); box-shadow: none;">分享给盟友</button>
    </view>

    <view class="tab-bar-spacer"></view>
  </view>
</view>
