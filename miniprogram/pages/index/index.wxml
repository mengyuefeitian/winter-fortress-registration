<!--pages/index/index.wxml-->
<view class="page">

  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-state">
    <view class="card p-24 mb-16">
      <view class="text-center">
        <text class="text-2xl font-semibold">无尽冬日堡垒分配</text>
        <text class="text-secondary mt-8">联盟报名管理系统</text>
      </view>
    </view>
    <text class="text-secondary mb-16">请先登录以使用完整功能</text>
    <button class="btn btn-primary btn-lg" bindtap="handleLogin">登录授权</button>
  </view>

  <!-- 已登录状态 -->
  <view wx:else class="container">

    <!-- 用户信息卡片 -->
    <view class="card mt-16">
      <view class="card-body flex items-center">
        <image class="avatar-lg" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="ml-16 flex-1">
          <text class="text-lg font-semibold">{{userInfo.nickName || '未设置昵称'}}</text>
          <view class="flex items-center mt-8">
            <view class="status-dot status-active"></view>
            <text class="text-secondary">{{roleDisplayName}}</text>
          </view>
        </view>
        <!-- 分区选择器 -->
        <view wx:if="{{zones.length > 0}}" class="picker">
          <picker mode="selector" range="{{zones}}" range-key="zoneName" value="{{zoneIndex}}" bindchange="onZoneChange">
            <view class="flex items-center">
              <text class="text-sm">{{currentZone.zoneName}}</text>
              <text class="text-weak ml-4">▼</text>
            </view>
          </picker>
        </view>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="section-header mt-24">
      <text class="section-title">功能</text>
    </view>

    <view class="function-grid">
      <!-- 堡垒报名 -->
      <view class="function-card" bindtap="goToFortressRegistration" wx:if="{{showFortressRegistration}}">
        <view class="function-icon">
          <image src="/images/icon-registration.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">堡垒报名</text>
          <text class="function-desc">选择时间段报名参加堡垒活动</text>
        </view>
      </view>

      <!-- 官职报名 -->
      <view class="function-card" bindtap="goToPositionRegistration" wx:if="{{showPositionRegistration}}">
        <view class="function-icon">
          <image src="/images/icon-alliance.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">官职报名</text>
          <text class="function-desc">预约官职时间段</text>
        </view>
      </view>

      <!-- 我的报名 -->
      <view class="function-card" bindtap="goToMyRegistrations" wx:if="{{showMyRegistrations}}">
        <view class="function-icon">
          <image src="/images/icon-review.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">我的报名</text>
          <text class="function-desc">查看报名记录和状态</text>
        </view>
      </view>

      <!-- 申请盟管 -->
      <view class="function-card" bindtap="applyAllianceManager" wx:if="{{showApplyAllianceManager}}">
        <view class="function-icon">
          <image src="/images/icon-auditor.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">申请盟管</text>
          <text class="function-desc">申请成为盟管管理官职</text>
        </view>
      </view>

      <!-- 申请区管 -->
      <view class="function-card" bindtap="applyZoneManager" wx:if="{{showApplyZoneManager}}">
        <view class="function-icon">
          <image src="/images/icon-admin.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">申请区管</text>
          <text class="function-desc">申请成为区管管理分区</text>
        </view>
      </view>

      <!-- 区管控制台 -->
      <view class="function-card" bindtap="goToAdminConsole" wx:if="{{showAdminConsole}}">
        <view class="function-icon">
          <image src="/images/icon-zone.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">区管控制台</text>
          <text class="function-desc">管理分区和联盟配置</text>
        </view>
      </view>

      <!-- 盟管控制台 -->
      <view class="function-card" bindtap="goToAuditorConsole" wx:if="{{showAuditorConsole}}">
        <view class="function-icon">
          <image src="/images/icon-time.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">盟管控制台</text>
          <text class="function-desc">配置时间段备注</text>
        </view>
      </view>

      <!-- 超管控制台 -->
      <view class="function-card" bindtap="goToSuperAdminConsole" wx:if="{{showSuperAdminConsole}}">
        <view class="function-icon">
          <image src="/images/icon-superadmin.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">超管控制台</text>
          <text class="function-desc">全局管理和审核</text>
        </view>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="text-center mt-32 mb-16">
      <text class="text-weak text-xs">无尽冬日堡垒分配 v1.0.0</text>
    </view>
  </view>
</view>