<!--pages/index/index.wxml-->
<view class="page">

  <!-- 未登录状态：显示功能列表和登录入口 -->
  <view wx:if="{{!isLoggedIn}}" class="container">
    <!-- 欢迎卡片 + 登录按钮 -->
    <view class="card mt-16">
      <view class="card-body flex items-center">
        <image class="avatar-lg" src="/images/default-avatar.png" mode="aspectFill" />
        <view class="ml-16 flex-1">
          <text class="text-lg font-semibold">无尽冬日活动管理</text>
          <text class="text-secondary text-sm mt-4">联盟报名管理系统</text>
        </view>
        <button class="btn btn-primary btn-sm" bindtap="handleLogin">登录</button>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="section-header mt-24">
      <text class="section-title">功能</text>
    </view>

    <view class="function-grid">
      <!-- 堡垒报名 -->
      <view class="function-card" bindtap="goToFortressRegistration" wx:if="{{showFortressRegistration}}">
        <view class="function-icon">
          <image src="/images/logo-fortress.svg" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">堡垒报名</text>
          <text class="function-desc">选择时间段报名堡垒活动</text>
        </view>
      </view>

      <!-- 官职报名 -->
      <view class="function-card" bindtap="goToPositionRegistration" wx:if="{{showPositionRegistration}}">
        <view class="function-icon">
          <image src="/images/icon-alliance.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">官职报名</text>
          <text class="function-desc">预约官职时间段</text>
        </view>
      </view>

      <!-- 国战报名 -->
      <view class="function-card" bindtap="goToBattleRegistration" wx:if="{{showBattleRegistration}}">
        <view class="function-icon">
          <image src="/images/logo-battle.svg" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">国战报名</text>
          <text class="function-desc">报名参与国战活动</text>
        </view>
      </view>

      <!-- 兵工厂报名 -->
      <view class="function-card" bindtap="goToArsenalRegistration" wx:if="{{showBattleRegistration}}">
        <view class="function-icon">
          <image src="/images/logo-arsenal.svg" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">兵工厂报名</text>
          <text class="function-desc">报名兵工厂活动</text>
        </view>
      </view>

      <!-- 峡谷会战报名 -->
      <view class="function-card" bindtap="goToCanyonRegistration" wx:if="{{showBattleRegistration}}">
        <view class="function-icon">
          <image src="/images/logo-canyon.svg" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">峡谷会战报名</text>
          <text class="function-desc">报名峡谷会战活动</text>
        </view>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="text-center mt-32 mb-16">
      <text class="text-weak text-xs">{{versionText}}</text>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view wx:if="{{isLoggedIn}}" class="container">

    <!-- 用户信息卡片 -->
    <view class="card mt-16">
      <view class="card-body flex items-center">
        <image class="avatar-lg" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="ml-16 flex-1">
          <text class="text-lg font-semibold">{{userInfo.nickName || '未设置昵称'}}</text>
          <view class="flex items-center mt-8">
            <view class="status-dot status-active"></view>
            <text class="text-secondary">{{roleDisplayName}}</text>
          </view>
        </view>
        <!-- 分区选择器 -->
        <zone-selector value="{{currentZone}}" zones="{{zones}}" loaded="{{zonesLoaded}}" bind:change="onZoneChange" />
      </view>
    </view>

    <!-- 分区引导：未选择分区 -->
    <view wx:if="{{zonesLoaded && zones.length > 0 && !currentZone}}" class="zone-guide-card">
      <text class="zone-guide-text">请选择您的分区，以便查看对应联盟和报名信息</text>
      <text class="zone-guide-desc">找不到您的分区？可以申请开通新分区</text>
      <view class="zone-guide-btn" bindtap="applyCreateZone">申请开通分区</view>
    </view>

    <!-- 分区引导：暂无分区 -->
    <view wx:if="{{zonesLoaded && zones.length === 0}}" class="zone-guide-card zone-guide-empty">
      <text class="zone-guide-text">当前暂无分区</text>
      <text class="zone-guide-desc">请联系区管开通，或申请创建新分区</text>
      <view class="zone-guide-btn" bindtap="applyCreateZone">申请开通分区</view>
    </view>

    <!-- 功能入口 -->
    <view class="section-header mt-24">
      <text class="section-title">功能</text>
    </view>

    <view class="function-grid">
      <!-- 堡垒报名 -->
      <view class="function-card" bindtap="goToFortressRegistration" wx:if="{{showFortressRegistration}}">
        <view class="function-icon">
          <image src="/images/logo-fortress.svg" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">堡垒报名</text>
          <text class="function-desc">选择时间段报名堡垒活动</text>
        </view>
      </view>

      <!-- 官职报名 -->
      <view class="function-card" bindtap="goToPositionRegistration" wx:if="{{showPositionRegistration}}">
        <view class="function-icon">
          <image src="/images/icon-alliance.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">官职报名</text>
          <text class="function-desc">预约官职时间段</text>
        </view>
      </view>

      <!-- 国战报名 -->
      <view class="function-card" bindtap="goToBattleRegistration" wx:if="{{showBattleRegistration}}">
        <view class="function-icon">
          <image src="/images/logo-battle.svg" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">国战报名</text>
          <text class="function-desc">报名参与国战活动</text>
        </view>
      </view>

      <!-- 兵工厂报名 -->
      <view class="function-card" bindtap="goToArsenalRegistration" wx:if="{{showBattleRegistration}}">
        <view class="function-icon">
          <image src="/images/logo-arsenal.svg" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">兵工厂报名</text>
          <text class="function-desc">报名兵工厂活动</text>
        </view>
      </view>

      <!-- 峡谷会战报名 -->
      <view class="function-card" bindtap="goToCanyonRegistration" wx:if="{{showBattleRegistration}}">
        <view class="function-icon">
          <image src="/images/logo-canyon.svg" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">峡谷会战报名</text>
          <text class="function-desc">报名峡谷会战活动</text>
        </view>
      </view>

      <!-- 我的报名 -->
      <view class="function-card" bindtap="goToMyRegistrations" wx:if="{{showMyRegistrations}}">
        <view class="function-icon">
          <image src="/images/icon-review.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">我的报名</text>
          <text class="function-desc">查看已报名成功的记录</text>
        </view>
      </view>

      <!-- 申请盟管 -->
      <view class="function-card" bindtap="applyAllianceManager" wx:if="{{showApplyAllianceManager}}">
        <view class="function-icon">
          <image src="/images/icon-auditor.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">申请盟管</text>
          <text class="function-desc">申请成为联盟管理，预约堡垒</text>
        </view>
      </view>

      <!-- 申请区管 -->
      <view class="function-card" bindtap="applyZoneManager" wx:if="{{showApplyZoneManager}}">
        <view class="function-icon">
          <image src="/images/icon-admin.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">申请区管</text>
          <text class="function-desc">申请成为分区管理员，预约官职</text>
        </view>
      </view>

      <!-- 盟管控制台 -->
      <view class="function-card" bindtap="goToAuditorConsole" wx:if="{{showAuditorConsole}}">
        <view class="function-icon">
          <image src="/images/icon-time.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">盟管控制台</text>
          <text class="function-desc">配置时间段备注</text>
        </view>
      </view>

      <!-- 区管控制台 -->
      <view class="function-card" bindtap="goToAdminConsole" wx:if="{{showAdminConsole}}">
        <view class="function-icon">
          <image src="/images/icon-zone.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">区管控制台</text>
          <text class="function-desc">管理分区和联盟配置</text>
        </view>
        <view wx:if="{{pendingAdminReviewCount > 0}}" class="badge badge-danger">{{pendingAdminReviewCount}}</view>
      </view>

      <!-- 超管控制台 -->
      <view class="function-card" bindtap="goToSuperAdminConsole" wx:if="{{showSuperAdminConsole}}">
        <view class="function-icon">
          <image src="/images/icon-superadmin.png" style="width: 32px; height: 32px;" />
        </view>
        <view class="function-content">
          <text class="function-name">超管控制台</text>
          <text class="function-desc">全局管理和审核</text>
        </view>
        <view wx:if="{{pendingReviewCount > 0}}" class="badge badge-danger">{{pendingReviewCount}}</view>
      </view>
    </view>

    <!-- 分享按钮 -->
    <view class="text-center mt-32">
      <button class="btn-share" open-type="share">分享给好友</button>
    </view>

    <!-- 底部说明 -->
    <view class="text-center mt-16 mb-16">
      <text class="text-weak text-xs">{{versionText}}</text>
    </view>
  </view>
</view>