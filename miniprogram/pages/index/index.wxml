<!--pages/index/index.wxml-->
<view class="index-container">

  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="login-tip">
    <view class="header-section">
      <view class="header-title">无尽冬日堡垒分配</view>
      <view class="header-desc">联盟报名管理系统</view>
    </view>
    <view class="login-tip-text">请先登录以使用完整功能</view>
    <button class="login-btn" bindtap="handleLogin">登录授权</button>
  </view>

  <!-- 已登录状态 -->
  <view wx:else>

    <!-- 头部欢迎区域 -->
    <view class="header-section">
      <view class="header-title">无尽冬日堡垒分配</view>
      <view class="header-desc">联盟报名管理系统</view>
    </view>

    <!-- 用户信息区域 -->
    <view class="user-section">
      <view class="user-info">
        <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="user-detail">
          <view class="user-name">{{userInfo.nickName || '用户'}}</view>
          <view class="user-role-tag">{{roleName}}</view>
        </view>
      </view>
    </view>

    <!-- 角色切换区域 -->
    <view class="role-section">
      <view class="section-title">切换身份</view>
      <view class="role-grid">
        <!-- 普通用户 -->
        <view class="role-card {{currentRole === 'user' ? 'active' : ''}}" bindtap="switchRole" data-role="user">
          <image class="role-icon" src="/images/icon-user.png"></image>
          <view class="role-name">普通用户</view>
          <view class="role-desc">报名参加联盟活动</view>
        </view>

        <!-- 管理员 -->
        <view class="role-card {{currentRole === 'admin' ? 'active' : ''}} {{canBeAdmin ? '' : 'disabled'}}" bindtap="switchRole" data-role="admin">
          <image class="role-icon" src="/images/icon-admin.png"></image>
          <view class="role-name">管理员</view>
          <view class="role-desc">管理分区和联盟配置</view>
        </view>

        <!-- 审计员 -->
        <view class="role-card {{currentRole === 'auditor' ? 'active' : ''}} {{canBeAuditor ? '' : 'disabled'}}" bindtap="switchRole" data-role="auditor">
          <image class="role-icon" src="/images/icon-auditor.png"></image>
          <view class="role-name">审计员</view>
          <view class="role-desc">配置时间段和查看数据</view>
        </view>

        <!-- 超级管理员 -->
        <view class="role-card {{currentRole === 'superAdmin' ? 'active' : ''}} {{isSuperAdmin ? '' : 'disabled'}}" bindtap="switchRole" data-role="superAdmin">
          <image class="role-icon" src="/images/icon-superadmin.png"></image>
          <view class="role-name">超级管理员</view>
          <view class="role-desc">全局管理和审核</view>
        </view>
      </view>

      <!-- 申请管理员提示 -->
      <view wx:if="{{!canBeAdmin && currentRole === 'user'}}" class="apply-tip">
        <button class="btn-outline" bindtap="applyAdmin">申请成为管理员</button>
      </view>
    </view>

    <!-- 快捷功能入口 -->
    <view class="function-section">
      <view class="section-title">快捷入口</view>
      <view class="function-grid">
        <!-- 根据角色显示不同功能 -->
        <view wx:if="{{currentRole === 'user'}}" class="function-item" bindtap="goToRegistration">
          <image class="function-icon" src="/images/icon-registration.png"></image>
          <view class="function-name">报名</view>
        </view>

        <view wx:if="{{isAdminOrAbove}}" class="function-item" bindtap="goToStatistics">
          <image class="function-icon" src="/images/icon-stats.png"></image>
          <view class="function-name">数据统计</view>
        </view>

        <view wx:if="{{canManageZone}}" class="function-item" bindtap="goToZoneManage">
          <image class="function-icon" src="/images/icon-zone.png"></image>
          <view class="function-name">分区管理</view>
        </view>

        <view wx:if="{{canConfigTimeSlot}}" class="function-item" bindtap="goToTimeSlotConfig">
          <image class="function-icon" src="/images/icon-time.png"></image>
          <view class="function-name">时间配置</view>
        </view>

        <view wx:if="{{canReviewAdmin}}" class="function-item" bindtap="goToAdminReview">
          <image class="function-icon" src="/images/icon-review.png"></image>
          <view class="function-name">审核申请</view>
        </view>

        <view wx:if="{{isSuperAdmin}}" class="function-item" bindtap="goToPhoneManage">
          <image class="function-icon" src="/images/icon-phone.png"></image>
          <view class="function-name">超管管理</view>
        </view>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="footer-section">
      无尽冬日堡垒分配 v1.0.0
    </view>
  </view>
</view>