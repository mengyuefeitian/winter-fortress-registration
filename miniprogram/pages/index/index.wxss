/* pages/index/index.wxss - Winter Fortress Style */
.page {
  min-height: 100vh;
}

.container {
  padding: 16px;
}

.section-header {
  margin-bottom: 16px;
}

.section-title {
  font-size: 13px;
  color: var(--wf-text-sub);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.grid-item {
  background: var(--wf-glass);
  border: 1px solid var(--wf-border);
  border-radius: 14px;
  height: 100px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.2s;
}

.grid-item:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.12);
}

.grid-icon {
  font-size: 32px;
  margin-bottom: 8px;
}
.grid-icon-img {
  width: 36px;
  height: 36px;
  margin-bottom: 8px;
}

.grid-name {
  font-size: 14px;
  color: var(--wf-text-main);
  font-weight: 500;
}

.badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--wf-danger);
  color: white;
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 10px;
  font-weight: 600;
}

.text-lg { font-size: 16px; }
.text-sm { font-size: 14px; }
.text-xs { font-size: 12px; }
.font-semibold { font-weight: 600; }
.text-secondary { color: var(--wf-text-sub); }
.mt-4 { margin-top: 4px; }
.mt-12 { margin-top: 12px; }
.mt-24 { margin-top: 24px; }
.mt-32 { margin-top: 32px; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
