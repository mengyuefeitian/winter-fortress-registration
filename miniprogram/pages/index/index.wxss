/* pages/index/index.wxss */

/* 页面容器 */
.page {
  min-height: 100vh;
  background-color: #fafbfc;
}

/* 页面特定样式 - 仅保留必要的 */

/* 未登录状态的居中布局 */
.empty-state {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
}

/* 功能卡片图标内的图片 */
.function-icon image {
  width: 32px;
  height: 32px;
}