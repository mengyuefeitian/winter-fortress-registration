/* 微信设计语言 - 紧凑布局 */
.page {
  padding: 12px;
  background-color: #F6F6F6;
  min-height: 100vh;
}

/* 卡片样式 - 紧凑 */
.card {
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

/* 表单行布局 - 两列 */
.form-row {
  display: flex;
  gap: 8px;
}

.form-col {
  flex: 1;
}

.form-label {
  font-size: 13px;
  color: #5F5F5F;
  margin-bottom: 4px;
  display: block;
}

/* 选择器样式 - 紧凑 */
.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 4px;
  padding: 8px 12px;
  height: 32px;
  font-size: 14px;
  color: #000000;
}

.picker.disabled {
  background-color: #F0F0F0;
}

.picker-placeholder {
  color: #A6A6A6;
}

.picker-arrow {
  width: 14px;
  height: 14px;
}

/* 按钮样式 */
.btn {
  font-size: 13px;
  border-radius: 4px;
  padding: 0 12px;
  height: 28px;
  line-height: 28px;
  border: none;
  box-sizing: border-box;
}

.btn-sm {
  font-size: 13px;
  height: 28px;
  line-height: 28px;
  padding: 0 12px;
}

.btn-primary {
  background-color: #07C160;
  color: #FFFFFF;
}

.btn-danger {
  background-color: #FA5151;
  color: #FFFFFF;
}

/* 统计标题 */
.stats-header {
  margin-bottom: 8px;
}

.stats-title {
  font-size: 16px;
  font-weight: 600;
  color: #000000;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.stats-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-bottom: 12px;
}

/* 汇总数据 */
.stats-summary {
  display: flex;
  justify-content: space-around;
  padding: 12px;
  background-color: #F5F5F5;
  border-radius: 6px;
  margin-bottom: 12px;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 22px;
  font-weight: 600;
  color: #07C160;
  margin-bottom: 4px;
}

.summary-label {
  font-size: 12px;
  color: #A6A6A6;
}

/* 时间段列表 */
.time-slot-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.time-slot-card {
  background-color: #F5F5F5;
  border-radius: 6px;
  padding: 12px;
}

.slot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.slot-time {
  font-size: 16px;
  font-weight: 600;
  color: #000000;
}

.slot-tag {
  display: inline-block;
  background-color: #07C160;
  color: #FFFFFF;
  font-size: 12px;
  padding: 2px 6px;
  border-radius: 4px;
  margin-left: 4px;
}

.slot-tag.fortress-tag {
  background-color: #4A90D9;
}

.slot-date {
  font-size: 13px;
  color: #A6A6A6;
  margin-top: 4px;
}

.slot-status {
  font-size: 14px;
  color: #5F5F5F;
  font-weight: 500;
}

.slot-status.full {
  color: #FA5151;
}

/* 报名人员列表 */
.registration-list {
  display: flex;
  flex-direction: column;
  border-top: 1px solid #E5E5E5;
  padding-top: 8px;
  margin-top: 8px;
}

.registration-item {
  display: flex;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #E5E5E5;
}

.registration-item:last-child {
  border-bottom: none;
}

.reg-order {
  width: 22px;
  height: 22px;
  background-color: #576B95;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 12px;
  text-align: center;
  line-height: 22px;
  margin-right: 10px;
}

.reg-name {
  flex: 1;
  font-size: 14px;
  color: #333333;
}

.reg-position {
  font-size: 12px;
  padding: 3px 8px;
  border-radius: 4px;
}

.reg-position.head {
  background-color: #FFE8E8;
  color: #FA5151;
}

.reg-position.body {
  background-color: #F0FFF0;
  color: #07C160;
}

.reg-time {
  font-size: 12px;
  color: #5F5F5F;
  margin-left: 6px;
}

/* 表格容器 */
.table-container {
  margin-bottom: 12px;
}

/* 表格行 */
.table-row {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #F0F0F0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-header-row {
  background-color: #F5F5F5;
  padding: 8px 0;
  border-radius: 4px;
  margin-bottom: 4px;
}

/* 表格单元格 */
.table-cell {
  flex: 1;
  font-size: 13px;
  color: #000000;
  text-align: center;
}

.table-header-row .table-cell {
  font-size: 12px;
  color: #5F5F5F;
  font-weight: 500;
}

.config-title {
  font-weight: 600;
}