/* pages/admin/time-slot-config/time-slot-config.wxss */

.time-slot-config-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16px;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 12px 16px;
}

.picker-arrow {
  width: 16px;
  height: 16px;
}

.add-slot-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 16px;
}

.add-slot-header {
  margin-bottom: 12px;
}

.add-slot-label {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
}

.add-slot-body {
  margin-bottom: 12px;
}

.time-picker-row {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.time-picker-label {
  font-size: 12px;
  color: #999999;
  width: 80px;
}

.time-picker {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 8px 12px;
}

.remark-row {
  display: flex;
  align-items: center;
}

.remark-label {
  font-size: 12px;
  color: #999999;
  width: 80px;
}

.remark-input {
  flex: 1;
  height: 36px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
}

.add-btn {
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 10px 20px;
  font-size: 14px;
  width: 100%;
}

.slot-list {
  display: flex;
  flex-direction: column;
}

.slot-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.slot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.slot-time {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.slot-actions {
  display: flex;
}

.edit-btn,
.delete-btn {
  font-size: 12px;
  padding: 6px 12px;
  border-radius: 6px;
  margin-left: 8px;
}

.edit-btn {
  background-color: #6BB3F0;
  color: #FFFFFF;
}

.delete-btn {
  background-color: transparent;
  color: #FF6B6B;
  border: 1px solid #FF6B6B;
}

.slot-remark {
  font-size: 12px;
  color: #999999;
  margin-bottom: 12px;
}

.edit-remark-section {
  margin-bottom: 12px;
}

.edit-remark-input {
  width: 100%;
  height: 36px;
  background-color: #FFFFFF;
  border: 1px solid #4A90D9;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
  margin-bottom: 8px;
}

.edit-remark-actions {
  display: flex;
  justify-content: flex-end;
}

.save-remark-btn,
.cancel-remark-btn {
  font-size: 12px;
  padding: 6px 16px;
  border-radius: 6px;
  margin-left: 8px;
}

.save-remark-btn {
  background-color: #4A90D9;
  color: #FFFFFF;
}

.cancel-remark-btn {
  background-color: transparent;
  color: #999999;
  border: 1px solid #E8E8E8;
}

.slot-info {
  display: flex;
  justify-content: space-between;
}

.slot-count,
.slot-status {
  font-size: 12px;
  color: #666666;
}