/* pages/admin/time-slot-config/time-slot-config.wxss */
/* 微信设计语言 - 紧凑布局 */

.page {
  padding: 12px;
  background-color: #F6F6F6;
  min-height: 100vh;
}

/* 卡片样式 - 紧凑 */
.card {
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

/* 表单行布局 - 两列 */
.form-row {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.form-col {
  flex: 1;
}

.form-col-full {
  flex: 1;
  width: 100%;
}

.form-label {
  font-size: 13px;
  color: #5F5F5F;
  margin-bottom: 4px;
  display: block;
}

/* 选择器样式 - 紧凑 */
.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 4px;
  padding: 8px 12px;
  height: 32px;
  font-size: 14px;
  color: #000000;
}

.picker-compact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #F5F5F5;
  border-radius: 4px;
  padding: 8px 12px;
  height: 32px;
  font-size: 14px;
  color: #000000;
}

.picker-small {
  padding: 3px 8px;
  height: 24px;
  font-size: 12px;
}

.picker.disabled {
  color: #A6A6A6;
}

/* 标签选择行 */
.tags-row {
  flex-direction: column;
}

.tag-options {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 4px;
}

.tag-option {
  background-color: #F5F5F5;
  border: 1px solid #E5E5E5;
  border-radius: 4px;
  padding: 6px 10px;
  font-size: 13px;
  color: #5F5F5F;
}

.tag-option.active {
  background-color: #07C160;
  border-color: #07C160;
  color: #FFFFFF;
}

/* 堡垒名称标签（单选）- 蓝色主题 */
.fortress-tag-option.active {
  background-color: #4A90D9;
  border-color: #4A90D9;
  color: #FFFFFF;
}

/* 按钮样式 */
.btn {
  font-size: 15px;
  border-radius: 4px;
  height: 40px;
  line-height: 40px;
  border: none;
}

.btn-primary {
  background-color: #07C160;
  color: #FFFFFF;
}

.btn-full {
  width: 100%;
}

/* 分区标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 12px 0 8px;
  padding-left: 4px;
}

.section-title {
  font-size: 15px;
  font-weight: 500;
  color: #5F5F5F;
}

.section-count {
  font-size: 13px;
  color: #A6A6A6;
}

/* 加载和空状态 */
.loading-container {
  display: flex;
  justify-content: center;
  padding: 16px;
}

.loading-text {
  color: #A6A6A6;
  font-size: 14px;
}

.empty-state {
  display: flex;
  justify-content: center;
  padding: 16px;
}

.empty-text {
  color: #A6A6A6;
  font-size: 14px;
}

/* 批量操作栏 */
.batch-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 12px;
  background-color: #FFFFFF;
  border-radius: 8px;
  margin-bottom: 8px;
}

.batch-select {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 14px;
  color: #5F5F5F;
}

.batch-delete-btn {
  background-color: #FA5151;
  color: #FFFFFF;
  font-size: 13px;
  padding: 0 12px;
  height: 28px;
  line-height: 28px;
  border-radius: 4px;
  box-sizing: border-box;
}

.batch-delete-btn[disabled] {
  background-color: #CCCCCC;
}

/* 时间段列表 */
.slot-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.slot-card {
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 12px;
  display: flex;
  gap: 12px;
}

.slot-checkbox {
  display: flex;
  align-items: center;
}

.slot-content {
  flex: 1;
}

.slot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.slot-time {
  font-size: 16px;
  font-weight: 500;
  color: #000000;
}

.slot-tag {
  display: inline-block;
  background-color: #07C160;
  color: #FFFFFF;
  font-size: 12px;
  padding: 2px 6px;
  border-radius: 4px;
  margin-left: 4px;
}

.slot-tag.fortress-tag {
  background-color: #4A90D9;
}

/* 编辑行 */
.edit-row {
  margin-bottom: 6px;
}

.slot-count {
  font-size: 14px;
  color: #5F5F5F;
}

.slot-date {
  font-size: 13px;
  color: #A6A6A6;
  margin-top: 4px;
}

.slot-actions {
  display: flex;
  gap: 6px;
  margin-top: 8px;
}

.edit-btn {
  background-color: #576B95;
  color: #FFFFFF;
  font-size: 13px;
  padding: 0 10px;
  height: 28px;
  line-height: 28px;
  border-radius: 4px;
}

.delete-btn {
  background-color: #FA5151;
  color: #FFFFFF;
  font-size: 13px;
  padding: 0 10px;
  height: 28px;
  line-height: 28px;
  border-radius: 4px;
}

/* 编辑标签区域 */
.edit-tag-section {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid #F0F0F0;
}

.edit-label {
  font-size: 13px;
  color: #5F5F5F;
  margin-bottom: 6px;
}

.edit-tag-options {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.edit-tag-option {
  background-color: #F5F5F5;
  border: 1px solid #E5E5E5;
  border-radius: 4px;
  padding: 4px 8px;
  font-size: 12px;
  color: #5F5F5F;
}

.edit-tag-option.active {
  background-color: #07C160;
  border-color: #07C160;
  color: #FFFFFF;
}

/* 编辑模式堡垒名称标签（单选）- 蓝色主题 */
.edit-fortress-options {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.edit-fortress-option {
  background-color: #F5F5F5;
  border: 1px solid #E5E5E5;
  border-radius: 4px;
  padding: 4px 8px;
  font-size: 12px;
  color: #5F5F5F;
}

.edit-fortress-option.active {
  background-color: #4A90D9;
  border-color: #4A90D9;
  color: #FFFFFF;
}

.edit-actions {
  display: flex;
  gap: 6px;
  margin-top: 8px;
}

.save-btn {
  background-color: #07C160;
  color: #FFFFFF;
  font-size: 13px;
  padding: 0 16px !important;
  height: 28px !important;
  min-height: 28px;
  line-height: 1;
  border-radius: 4px;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn::after {
  border: none;
}

.cancel-btn {
  background-color: #E5E5E5;
  color: #5F5F5F;
  font-size: 13px;
  padding: 0 16px !important;
  height: 28px !important;
  min-height: 28px;
  line-height: 1;
  border-radius: 4px;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn::after {
  border: none;
}