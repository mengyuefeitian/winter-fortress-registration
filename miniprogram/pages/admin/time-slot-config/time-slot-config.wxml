<!--pages/admin/time-slot-config/time-slot-config.wxml-->
<view class="time-slot-config-container">
  <!-- 选择分区 -->
  <view class="section">
    <view class="section-title">选择分区</view>
    <picker wx:if="{{zones.length > 0}}" bindchange="onZoneChange" value="{{zoneIndex}}" range="{{zones}}" range-key="zoneName">
      <view class="picker">
        <text>{{selectedZone ? selectedZone.zoneName + ' (' + selectedZone.zoneCode + ')' : '请选择分区'}}</text>
        <image class="picker-arrow" src="/images/icon-arrow-down.png"></image>
      </view>
    </picker>
    <view wx:else class="empty-picker">
      <text>暂无分区，请先创建分区</text>
    </view>
  </view>

  <!-- 选择联盟 -->
  <view wx:if="{{selectedZone && alliances.length > 0}}" class="section">
    <view class="section-title">选择联盟</view>
    <picker bindchange="onAllianceChange" value="{{allianceIndex}}" range="{{alliances}}" range-key="allianceName">
      <view class="picker">
        <text>{{selectedAlliance ? selectedAlliance.allianceName : '请选择联盟'}}</text>
        <image class="picker-arrow" src="/images/icon-arrow-down.png"></image>
      </view>
    </picker>
  </view>

  <!-- 无联盟提示 -->
  <view wx:if="{{selectedZone && alliances.length === 0}}" class="section">
    <view class="empty-tip">该分区暂无联盟数据，请检查分区是否创建成功</view>
  </view>

  <!-- 时间段配置 -->
  <view wx:if="{{selectedAlliance}}" class="section">
    <view class="section-title">时间段配置</view>

    <!-- 添加时间段 -->
    <view class="add-slot-card">
      <view class="add-slot-header">
        <view class="add-slot-label">添加时间段</view>
      </view>

      <view class="add-slot-body">
        <!-- 选择基础时间 -->
        <view class="time-picker-row">
          <view class="time-picker-label">基础时间</view>
          <picker bindchange="onBaseTimeChange" value="{{selectedTimeIndex}}" range="{{TIME_OPTIONS}}" range-key="label">
            <view class="time-picker">
              <text>{{selectedTime.label}}</text>
              <image class="picker-arrow" src="/images/icon-arrow-down.png"></image>
            </view>
          </picker>
        </view>

        <!-- 备注 -->
        <view class="remark-row">
          <view class="remark-label">备注</view>
          <input class="remark-input" placeholder="可选，添加备注信息" value="{{newRemark}}" bindinput="onRemarkInput" maxlength="50" />
        </view>
      </view>

      <button class="add-btn" bindtap="addTimeSlot">添加时间段</button>
    </view>

    <!-- 时间段列表 -->
    <view class="slot-list">
      <view wx:if="{{timeSlots.length === 0}}" class="empty-tip">暂无时间段，请添加</view>

      <view wx:for="{{timeSlots}}" wx:key="_id" class="slot-card">
        <view class="slot-header">
          <view class="slot-time">{{item.displayName}}</view>
          <view class="slot-actions">
            <button class="edit-btn" bindtap="editRemark" data-index="{{index}}">编辑备注</button>
            <button class="delete-btn" bindtap="deleteTimeSlot" data-id="{{item._id}}" data-index="{{index}}">删除</button>
          </view>
        </view>

        <view wx:if="{{item.remark}}" class="slot-remark">备注: {{item.remark}}</view>

        <!-- 编辑备注 -->
        <view wx:if="{{item.editing}}" class="edit-remark-section">
          <input class="edit-remark-input" placeholder="输入备注" value="{{item.editRemark}}" bindinput="onEditRemarkInput" data-index="{{index}}" />
          <view class="edit-remark-actions">
            <button class="save-remark-btn" bindtap="saveRemark" data-id="{{item._id}}" data-index="{{index}}">保存</button>
            <button class="cancel-remark-btn" bindtap="cancelEditRemark" data-index="{{index}}">取消</button>
          </view>
        </view>

        <view class="slot-info">
          <view class="slot-count">最大人数: {{item.maxCount}}人</view>
          <view class="slot-status">当前报名: {{item.currentCount}}人</view>
        </view>
      </view>
    </view>
  </view>
</view>