<!--pages/admin/zone-manage/zone-manage.wxml-->
<view class="zone-manage-container">
  <!-- 新建分区 -->
  <view class="section">
    <view class="section-title">新建分区</view>
    <view class="form-card">
      <view class="form-item">
        <view class="form-label">分区编号</view>
        <input class="form-input" placeholder="请输入1-4位数字" value="{{newZoneCode}}" bindinput="onZoneCodeInput" maxlength="4" type="number" />
      </view>
      <view class="form-item">
        <view class="form-label">分区名称</view>
        <input class="form-input" placeholder="请输入分区名称" value="{{newZoneName}}" bindinput="onZoneNameInput" maxlength="20" />
      </view>
      <button class="create-btn" bindtap="createZone">创建分区</button>
    </view>
  </view>

  <!-- 分区列表 -->
  <view class="list-section">
    <view class="section-title">分区列表</view>
    <view wx:if="{{zones.length === 0}}" class="empty-state">
      <view class="empty-text">暂无分区</view>
    </view>
    <view wx:else class="zone-list">
      <view wx:for="{{zones}}" wx:key="_id" class="zone-card">
        <view class="zone-header">
          <view class="zone-code">{{item.zoneCode}}</view>
          <view class="zone-name">{{item.zoneName}}</view>
        </view>
        <view class="zone-info">
          <view class="info-item">
            <view class="info-label">创建时间</view>
            <view class="info-value">{{item.formattedTime}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">联盟数量</view>
            <view class="info-value">{{item.allianceCount || 0}}个</view>
          </view>
        </view>
        <view class="zone-actions">
          <button class="action-btn edit-btn" bindtap="editZone" data-zone="{{item}}" wx:if="{{isSuperAdmin}}">修改编号</button>
          <button class="action-btn config-btn" bindtap="goToAllianceConfig" data-zone="{{item}}">配置联盟</button>
          <button class="action-btn delete-btn" bindtap="deleteZone" data-id="{{item._id}}" data-index="{{index}}" wx:if="{{isSuperAdmin}}">删除</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 编辑分区弹窗 -->
  <view wx:if="{{showEditModal}}" class="modal-mask" bindtap="closeEditModal">
    <view class="modal-content" catchtap>
      <view class="modal-title">修改分区编号</view>
      <view class="modal-body">
        <view class="form-item">
          <view class="form-label">分区编号</view>
          <input class="form-input" placeholder="请输入1-4位数字" value="{{editZoneCode}}" bindinput="onEditZoneCodeInput" maxlength="4" type="number" />
        </view>
        <view class="form-item">
          <view class="form-label">分区名称</view>
          <input class="form-input" placeholder="请输入分区名称" value="{{editZoneName}}" bindinput="onEditZoneNameInput" maxlength="20" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeEditModal">取消</button>
        <button class="modal-btn confirm" bindtap="saveEditZone">保存</button>
      </view>
    </view>
  </view>
</view>