/* pages/admin/zone-manage/zone-manage.wxss */

.zone-manage-container {
  padding: 20px;
  #removed-bg
  min-height: 100vh;
}

.create-section,
.list-section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16px;
}

.form-card {
  padding: 16px;
  background-color: #F5F7FA;
  border-radius: 8px;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #666666;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 40px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
}

.create-btn {
  background-color: #07C160;
  color: #FFFFFF;
  border-radius: 6px;
  padding: 8px 16px;
  font-size: 14px;
  width: auto;
  margin-top: 8px;
}

.empty-state {
  padding: 40px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #999999;
}

.zone-list {
  display: flex;
  flex-direction: column;
}

.zone-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.zone-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.zone-code {
  background-color: #576B95;
  color: #FFFFFF;
  font-size: 14px;
  padding: 4px 12px;
  border-radius: 4px;
  margin-right: 12px;
}

.zone-name {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.zone-info {
  margin-bottom: 12px;
}

.info-item {
  display: flex;
  margin-bottom: 8px;
}

.info-label {
  font-size: 12px;
  color: #999999;
  width: 80px;
}

.info-value {
  font-size: 12px;
  color: #666666;
}

.zone-actions {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
}

.action-btn {
  font-size: 12px;
  padding: 0 12px;
  height: 28px;
  line-height: 28px;
  border-radius: 6px;
  flex: 1;
  min-width: 80px;
  box-sizing: border-box;
}

.edit-btn {
  background-color: #52C41A;
  color: #FFFFFF;
}

.config-btn {
  background-color: #6BB3F0;
  color: #FFFFFF;
}

.delete-btn {
  background-color: transparent;
  color: #FF6B6B;
  border: 1px solid #FF6B6B;
}

/* 编辑弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background-color: #FFFFFF;
  border-radius: 12px;
  overflow: hidden;
}

.modal-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  padding: 16px;
  text-align: center;
  border-bottom: 1px solid #E8E8E8;
}

.modal-body {
  padding: 16px;
}

.modal-footer {
  display: flex;
  border-top: 1px solid #E8E8E8;
}

.modal-btn {
  flex: 1;
  padding: 14px;
  font-size: 15px;
  border-radius: 0;
  background-color: #FFFFFF;
}

.modal-btn.cancel {
  color: #666666;
  border-right: 1px solid #E8E8E8;
}

.modal-btn.confirm {
  color: #07C160;
}

/* ===== Dark Theme Override ===== */
.page, .alliance-config-container, .zone-manage-container,
.alliance-manage-container, .auto-clear-container, .phone-manage-container {
  background: transparent !important;
  color: #F8FAFC;
}
.section, .card, .time-slot-card, .member-card, .review-item,
.stat-card, .stat-section, .alliance-card, .zone-card,
.auditor-section, .config-card, .review-card, .phone-card,
.identity-card, .auto-clear-card {
  background-color: rgba(255,255,255,0.07) !important;
  border: 1px solid rgba(255,255,255,0.13) !important;
}
.section-title, .card-title, .form-label, .zone-name, .alliance-name,
.member-name, .user-name, .stat-label, .config-label,
.page-title, .review-status, .phone-label {
  color: #F8FAFC !important;
}
.section-desc, .zone-desc, .member-role, .stat-value,
.text-weak, .text-secondary, .sub-text, .review-desc, .config-desc {
  color: #94A3B8 !important;
}
.edit-input, .form-input, .search-input, .input {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.picker-compact, .picker-value {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.alliance-index, .alliance-header {
  background-color: rgba(56,189,248,0.12) !important;
  color: #38BDF8 !important;
  border-color: rgba(56,189,248,0.2) !important;
}
.status-tag, .status-badge, .tag, .role-tag {
  opacity: 0.9;
}
.divider, .card-divider, .section-divider {
  border-color: rgba(255,255,255,0.1) !important;
}

