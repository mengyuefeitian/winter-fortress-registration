/* pages/admin/zone-manage/zone-manage.wxss */

.zone-manage-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.create-section,
.list-section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16px;
}

.form-card {
  padding: 16px;
  background-color: #F5F7FA;
  border-radius: 8px;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #666666;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 40px;
  background-color: #FFFFFF;
  border: 1px solid #E8E8E8;
  border-radius: 6px;
  padding: 0 12px;
  font-size: 14px;
}

.create-btn {
  background-color: #4A90D9;
  color: #FFFFFF;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
  width: 100%;
}

.empty-state {
  padding: 40px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #999999;
}

.zone-list {
  display: flex;
  flex-direction: column;
}

.zone-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.zone-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.zone-code {
  background-color: #4A90D9;
  color: #FFFFFF;
  font-size: 14px;
  padding: 4px 12px;
  border-radius: 4px;
  margin-right: 12px;
}

.zone-name {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
}

.zone-info {
  margin-bottom: 12px;
}

.info-item {
  display: flex;
  margin-bottom: 8px;
}

.info-label {
  font-size: 12px;
  color: #999999;
  width: 80px;
}

.info-value {
  font-size: 12px;
  color: #666666;
}

.zone-actions {
  display: flex;
  justify-content: space-between;
}

.action-btn {
  font-size: 12px;
  padding: 8px 16px;
  border-radius: 6px;
  flex: 1;
  margin-right: 8px;
}

.action-btn:last-child {
  margin-right: 0;
}

.config-btn {
  background-color: #6BB3F0;
  color: #FFFFFF;
}

.delete-btn {
  background-color: transparent;
  color: #FF6B6B;
  border: 1px solid #FF6B6B;
}