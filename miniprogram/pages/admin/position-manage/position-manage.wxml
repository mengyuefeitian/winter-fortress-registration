<!-- pages/admin/position-manage/position-manage.wxml -->
<view class="page">
  <!-- 创建配置区域 - 紧凑布局 -->
  <view class="card">
    <!-- 第一行：分区 + 日期 -->
    <view class="form-row">
      <!-- 分区选择（超管可见） -->
      <view class="form-col" wx:if="{{showZonePicker && zones.length > 0}}">
        <text class="form-label">分区</text>
        <zone-selector value="{{currentZone}}" zones="{{zones}}" loaded="{{true}}" bind:change="onZoneChange" />
      </view>

      <!-- 超管无分区提示 -->
      <view class="form-col" wx:if="{{showZonePicker && zones.length === 0}}">
        <text class="form-label text-danger">无分区</text>
        <button class="btn btn-outline btn-sm" bindtap="goToZoneManage">创建</button>
      </view>

      <!-- 当前分区显示（区管） -->
      <view class="form-col" wx:if="{{!showZonePicker && currentZone}}">
        <text class="form-label">分区</text>
        <view class="picker-compact static">
          <text>{{currentZone.zoneName}}</text>
        </view>
      </view>

      <!-- 日期选择 -->
      <view class="form-col">
        <text class="form-label">日期</text>
        <picker mode="date" value="{{selectedDate}}" start="{{minDate}}" end="{{maxDate}}"
                bindchange="onDateChange">
          <view class="picker-compact">
            <text wx:if="{{selectedDate}}">{{selectedDate}}</text>
            <text class="picker-placeholder" wx:else>选择日期</text>
            <image class="picker-compact-arrow" src="/images/icon-arrow-down.png"></image>
          </view>
        </picker>
      </view>
    </view>

    <!-- 第二行：职位类型 + 起始时间 -->
    <view class="form-row">
      <!-- 职位类型选择 -->
      <view class="form-col">
        <text class="form-label">职位</text>
        <picker mode="selector" range="{{positionTypes}}" value="{{positionTypeIndex}}"
                bindchange="onPositionTypeChange">
          <view class="picker-compact">
            <text>{{positionTypes[positionTypeIndex]}}</text>
            <image class="picker-compact-arrow" src="/images/icon-arrow-down.png"></image>
          </view>
        </picker>
      </view>

      <!-- 起始时间选择 -->
      <view class="form-col">
        <text class="form-label">起始</text>
        <picker mode="selector" range="{{startTimes}}" value="{{startTimeIndex}}"
                bindchange="onStartTimeChange">
          <view class="picker-compact">
            <text>{{startTimes[startTimeIndex]}}</text>
            <image class="picker-compact-arrow" src="/images/icon-arrow-down.png"></image>
          </view>
        </picker>
      </view>
    </view>

    <!-- 创建按钮 -->
    <button class="btn btn-primary btn-full" bindtap="createConfig" disabled="{{!canCreate}}">
      创建配置
    </button>
  </view>

  <!-- 已创建配置列表 -->
  <view class="section-header">
    <text class="section-title">已创建配置</text>
  </view>

  <view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty-state" wx:if="{{!loading && configs.length === 0}}">
    <text class="empty-text">暂无配置</text>
  </view>

  <view class="config-list">
    <view class="config-card" wx:for="{{configs}}" wx:key="_id">
      <view class="config-header">
        <view class="config-info">
          <text class="config-title">{{item.positionType}}</text>
          <text class="config-date">{{item.date}}</text>
        </view>
        <view class="config-stats">{{item.registrationCount || 0}}人报名</view>
      </view>
      <view class="config-body">
        <text class="config-time">起始：{{item.startTime}}</text>
      </view>
      <view class="config-footer">
        <button class="btn btn-danger btn-sm" bindtap="clearData"
                data-config-id="{{item._id}}" data-config-info="{{item.positionType}} - {{item.date}}">清空</button>
        <button class="btn btn-ghost btn-sm" bindtap="deleteConfig"
                data-config-id="{{item._id}}" data-config-info="{{item.positionType}} - {{item.date}}">删除</button>
      </view>
    </view>
  </view>
</view>