/* pages/admin/position-manage/position-manage.wxss */
/* 微信设计语言 - 紧凑布局 */

.page {
  padding: 12px;
  #removed-bg
  min-height: 100vh;
}

.section-header {
  margin: 12px 0 8px;
  padding-left: 4px;
}

.section-title {
  font-size: 15px;
  font-weight: 500;
  color: #5F5F5F;
}

/* 卡片样式 - 紧凑 */
.card {
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

/* 表单行布局 - 两列 */
.form-row {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.form-col {
  flex: 1;
}

.form-label {
  font-size: 13px;
  color: #5F5F5F;
  margin-bottom: 4px;
  display: block;
}

/* 选择器样式 - 紧凑 */
.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 4px;
  padding: 8px 12px;
  height: 32px;
  font-size: 14px;
  color: #000000;
}

.picker-compact.static {
  background-color: #F0F0F0;
  color: #5F5F5F;
}

.picker-placeholder {
  color: #A6A6A6;
}

.picker-arrow {
  width: 14px;
  height: 14px;
}

/* 按钮样式 */
.btn {
  font-size: 15px;
  border-radius: 4px;
  padding: 0 16px;
  height: 44px;
  line-height: 44px;
  border: none;
}

.btn-primary {
  background-color: #07C160;
  color: #FFFFFF;
}

.btn-primary[disabled] {
  background-color: #CCCCCC;
  color: #FFFFFF;
}

.btn-danger {
  background-color: #FA5151;
  color: #FFFFFF;
}

.btn-ghost {
  background-color: #FFFFFF;
  color: #5F5F5F;
  border: 1px solid #E5E5E5;
}

.btn-outline {
  background-color: #FFFFFF;
  color: #07C160;
  border: 1px solid #07C160;
}

.btn-sm {
  font-size: 13px;
  height: 28px;
  line-height: 28px;
  padding: 0 12px;
}

.btn-full {
  width: 100%;
  margin-top: 8px;
}

/* 文本样式 */
.text-danger {
  color: #FA5151;
}

/* 配置列表 */
.config-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.config-card {
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 12px;
}

.config-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.config-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.config-title {
  font-size: 16px;
  font-weight: 500;
  color: #000000;
}

.config-date {
  font-size: 13px;
  color: #5F5F5F;
}

.config-stats {
  font-size: 13px;
  color: #07C160;
}

.config-body {
  margin-top: 6px;
}

.config-time {
  font-size: 13px;
  color: #A6A6A6;
}

.config-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid #F0F0F0;
}

/* 加载和空状态 */
.loading-container {
  display: flex;
  justify-content: center;
  padding: 16px;
}

.loading-text {
  color: #A6A6A6;
  font-size: 14px;
}

.empty-state {
  display: flex;
  justify-content: center;
  padding: 16px;
}

.empty-text {
  color: #A6A6A6;
  font-size: 14px;
}

/* ===== Dark Theme Override ===== */
.page, .alliance-config-container, .zone-manage-container,
.alliance-manage-container, .auto-clear-container, .phone-manage-container {
  background: transparent !important;
  color: #F8FAFC;
}
.section, .card, .time-slot-card, .member-card, .review-item,
.stat-card, .stat-section, .alliance-card, .zone-card,
.auditor-section, .config-card, .review-card, .phone-card,
.identity-card, .auto-clear-card {
  background-color: rgba(255,255,255,0.07) !important;
  border: 1px solid rgba(255,255,255,0.13) !important;
}
.section-title, .card-title, .form-label, .zone-name, .alliance-name,
.member-name, .user-name, .stat-label, .config-label,
.page-title, .review-status, .phone-label {
  color: #F8FAFC !important;
}
.section-desc, .zone-desc, .member-role, .stat-value,
.text-weak, .text-secondary, .sub-text, .review-desc, .config-desc {
  color: #94A3B8 !important;
}
.edit-input, .form-input, .search-input, .input {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.picker-compact, .picker-value {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.alliance-index, .alliance-header {
  background-color: rgba(56,189,248,0.12) !important;
  color: #38BDF8 !important;
  border-color: rgba(56,189,248,0.2) !important;
}
.status-tag, .status-badge, .tag, .role-tag {
  opacity: 0.9;
}
.divider, .card-divider, .section-divider {
  border-color: rgba(255,255,255,0.1) !important;
}

