/* 微信设计语言 - 紧凑布局 */
.page {
  padding: 12px;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 12px;
}

/* 按钮样式 */
.btn {
  font-size: 13px;
  border-radius: 4px;
  padding: 0 12px;
  height: 28px;
  line-height: 28px;
  border: none;
  box-sizing: border-box;
}

.btn-sm {
  font-size: 13px;
  height: 28px;
  line-height: 28px;
  padding: 0 12px;
}

.btn-primary {
  background-color: #07C160;
  color: #FFFFFF;
}

.btn-danger {
  background-color: #FA5151;
  color: #FFFFFF;
}

/* 统计标题 */
.stats-header {
  margin-bottom: 8px;
}

.stats-title {
  font-size: 16px;
  font-weight: 600;
  color: #000000;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.stats-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-bottom: 12px;
}

/* 汇总数据 */
.stats-summary {
  display: flex;
  justify-content: space-around;
  padding: 12px;
  background-color: #F5F5F5;
  border-radius: 6px;
  margin-bottom: 12px;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 22px;
  font-weight: 600;
  color: #07C160;
  margin-bottom: 4px;
}

.summary-label {
  font-size: 12px;
  color: #A6A6A6;
}

/* 时间段列表 */
.time-slot-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.time-slot-card {
  background-color: #F5F5F5;
  border-radius: 6px;
  padding: 12px;
}

.slot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.slot-time {
  font-size: 16px;
  font-weight: 600;
  color: #000000;
}

.slot-tag {
  display: inline-block;
  background-color: #07C160;
  color: #FFFFFF;
  font-size: 12px;
  padding: 2px 6px;
  border-radius: 4px;
  margin-left: 4px;
}

.slot-tag.fortress-tag {
  background-color: #4A90D9;
}

.slot-date {
  font-size: 13px;
  color: #A6A6A6;
  margin-top: 4px;
}

.slot-status {
  font-size: 14px;
  color: #5F5F5F;
  font-weight: 500;
}

.slot-status.full {
  color: #FA5151;
}

/* 报名人员列表 */
.registration-list {
  display: flex;
  flex-direction: column;
  border-top: 1px solid #E5E5E5;
  padding-top: 8px;
  margin-top: 8px;
}

.registration-item {
  display: flex;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #E5E5E5;
}

.registration-item:last-child {
  border-bottom: none;
}

.reg-order {
  width: 22px;
  height: 22px;
  background-color: #576B95;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 12px;
  text-align: center;
  line-height: 22px;
  margin-right: 10px;
}

.reg-name {
  flex: 1;
  font-size: 14px;
  color: #333333;
}

.reg-position {
  font-size: 12px;
  padding: 3px 8px;
  border-radius: 4px;
}

.reg-position.head,
.reg-position.combat {
  background-color: #FFE8E8;
  color: #FA5151;
}

.reg-position.body,
.reg-position.substitute {
  background-color: #F0FFF0;
  color: #07C160;
}

/* 空状态 */
.empty-state {
  padding: 32px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #A6A6A6;
}

/* ===== Dark Theme Override ===== */
.page, .alliance-config-container, .zone-manage-container,
.alliance-manage-container, .auto-clear-container, .phone-manage-container {
  background: transparent !important;
  color: #F8FAFC;
}
.section, .card, .time-slot-card, .member-card, .review-item,
.stat-card, .stat-section, .alliance-card, .zone-card,
.auditor-section, .config-card, .review-card, .phone-card,
.identity-card, .auto-clear-card {
  background-color: rgba(255,255,255,0.07) !important;
  border: 1px solid rgba(255,255,255,0.13) !important;
}
.section-title, .card-title, .form-label, .zone-name, .alliance-name,
.member-name, .user-name, .stat-label, .config-label,
.page-title, .review-status, .phone-label {
  color: #F8FAFC !important;
}
.section-desc, .zone-desc, .member-role, .stat-value,
.text-weak, .text-secondary, .sub-text, .review-desc, .config-desc {
  color: #94A3B8 !important;
}
.edit-input, .form-input, .search-input, .input {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.picker-compact, .picker-value {
  background-color: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.18) !important;
  color: #F8FAFC !important;
}
.alliance-index, .alliance-header {
  background-color: rgba(56,189,248,0.12) !important;
  color: #38BDF8 !important;
  border-color: rgba(56,189,248,0.2) !important;
}
.status-tag, .status-badge, .tag, .role-tag {
  opacity: 0.9;
}
.divider, .card-divider, .section-divider {
  border-color: rgba(255,255,255,0.1) !important;
}

