/* pages/auditor/home/home.wxss */

.auditor-home-container {
  padding: 20px;
  background-color: #F5F7FA;
  min-height: 100vh;
}

.header-section {
  background: linear-gradient(135deg, #6BB3F0 0%, #4A90D9 100%);
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 20px;
}

.header-title {
  font-size: 24px;
  font-weight: 500;
  color: #FFFFFF;
  margin-bottom: 8px;
}

.header-desc {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

.alliance-info-section {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16px;
}

.alliance-card {
  background-color: #F5F7FA;
  border-radius: 8px;
  padding: 16px;
}

.alliance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.alliance-name {
  font-size: 18px;
  font-weight: 500;
  color: #333333;
}

.alliance-zone {
  font-size: 14px;
  color: #999999;
}

.empty-state {
  padding: 20px;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #999999;
}

.function-grid {
  display: flex;
  flex-wrap: wrap;
}

.function-card {
  width: calc(50% - 8px);
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 20px 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  margin-right: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.function-card:nth-child(2n) {
  margin-right: 0;
}

.function-card:active {
  transform: scale(0.98);
  background-color: #F0F7FF;
}

.function-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 12px;
}

.function-name {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8px;
}

.function-desc {
  font-size: 12px;
  color: #999999;
  text-align: center;
}